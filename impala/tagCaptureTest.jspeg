# Regression grammar exercising tag and capture semantics
# Build a map from key/value pairs for regression coverage.
root        <-  _ { $$ = {}; } pair (_ ',' _ pair)* _ !.

pair        <-  key:Identifier _ '=' _ value:Number { $$[$key] = $value }
Identifier  <-  name=[a-zA-Z]+ { $$ = $name }
Number      <-  digits=[0-9]+ { $$ = +$digits }
_           <-  (' ' / '\t' / '\r' / '\n')*
