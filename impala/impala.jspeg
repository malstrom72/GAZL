            $$parser.makeMeta(
                x, rightx.operator, rightx.type,
                leftx.operands[1],
                rightx.operands[1],
                rightx.operands[2]
            );
            keep = ((x.operator === '=' || x.operator === ':=') ? 1 : 0);

        } else if (lop === '=*') {

            $$parser.makeMeta(
                x, '*=', rightx.type,
                leftx.operands[1],
                $$parser.makeRValue(rightx),
                null
            );
            keep = 1;

        } else if (lop === '=[]') {

            $$parser.makeMeta(
                x, '[]=', rightx.type,
                leftx.operands[1],
                leftx.operands[2],
                $$parser.makeRValue(rightx)
            );

        } else if (lop === '=[]$') {

            $$parser.makeMeta(
                x, '[]$=', rightx.type,
                leftx.operands[1],
                leftx.operands[2],
                $$parser.makeRValue(rightx)
            );

        } else {
            $$parser.fail("Invalid lvalue", sourceCode, sourceOffset, 'E404');
        }

        /* push the instruction just built */
        $$parser.emitMeta(x);

        /* release all temporaries except the one we keep */
        for (var i = 2; i >= 0; --i) {
            if (i !== keep) {
                $$parser.returnBack(x.operands[i]);
            }
        }

        /* finally generate r-value of assignment */
        $$parser.makeMeta(
            x, '=', x.type,
            null,
            x.operands[keep],
            null
        );
    };

    /* -----------------------------------------------------------
     *  Unary helpers  (dereference, reference, -, ~, abs/floor,
     *                  int↔float conversions)
     * -------------------------------------------------------- */

    /* *expr  or  [] dereference handling */
    $$parser.dereference = function (operator, expr, sourceCode, sourceOffset) {
        expr = metaSlot(expr);
        if (expr.operator === '+') {
            /*  &a + i   →   PEEK (&a , i)  */
            expr.operator = '=[]';
        } else if (expr.operator === '-' && expr.operands[2] &&
                   expr.operands[2][0] === '#') {
            /*  &a - #n  where n is const → adjust to negative literal */
            expr.operator = '=[]';
            var num = parseFloat(expr.operands[2].substr(1));   // strip leading '#'
            expr.operands[2] = '#'+(-num);
        } else {
            /* generic “*expr” */
            $$parser.makeMeta(
                expr, operator, '?',
                undefined,
                $$parser.makeRValue(expr),
                undefined
            );
        }
    };

    /* & (address-of) operator handling */
    $$parser.reference = function (operator, expr, sourceCode, sourceOffset) {

        expr = metaSlot(expr);

        if (expr.operator === '=') {                 // variable
            assert(expr.operands[2] === undefined,
                   "expr.operands[2] must be void for '=' lvalue");
            expr.operator  = '=&';
            expr.operands[2] = '*0';

        } else if (expr.operator === '=*' || expr.operator === ':=*') {
            assert(expr.operands[2] === undefined,
                   "expr.operands[2] must be void for '=*' lvalue");
            expr.operator = ':=';                    // treat as plain r-value

        } else if (expr.operator === '=[]') {        // array element
            expr.operator = '+';                     // &a[i]  →  &a + i

        } else if (expr.operator === '=[]$') {       // local array element
            expr.operator = '=&';
            var index = expr.operands[2];            // save index before clobber
            expr.operands[2] = '*0';
            $$parser.makeMeta(
                expr, '+', 'p',
                undefined,
                $$parser.makeRValue(expr),           // &base
                index                                // + offset
            );

        } else {
            $$parser.fail("Invalid lvalue", sourceCode, sourceOffset, 'E404');
        }
    };

    /* unary minus (integer/float) */
    $$parser.minus = function (operator, expr/*, src, off*/) {
        expr = metaSlot(expr);
        $$parser.makeMeta(
            expr, '-', undefined,
            undefined,
            $$parser.ZEROES[ expr.type ],            // 0  of same type
            $$parser.makeRValue(expr)
        );
    };

    /* bit-wise NOT / logical NOT  (~expr) */
    $$parser.not = function (operator, expr) {
        expr = metaSlot(expr);
        $$parser.makeMeta(
            expr, '^', undefined,
            undefined,
            $$parser.makeRValue(expr),
            '#-1'                                    // XOR with –1
        );
    };

    /* ABS or FLOOR (unary) – operator is already '=abs' or '=floor' */
    $$parser.absFloor = function (operator, expr) {
        expr = metaSlot(expr);
        $$parser.makeMeta(
            expr, operator, undefined,
            undefined,
            $$parser.makeRValue(expr),
            undefined
        );
    };

    /* int → float */
    $$parser.intToFloatConvert = function (operator, expr) {
        expr = metaSlot(expr);
        $$parser.makeMeta(
            expr, '=itof', undefined,
            undefined,
            $$parser.makeRValue(expr),
            '#1.0'
        );
    };

    /* float → int, with constant-fold special-case */
    $$parser.floatToIntConvert = function (operator, expr) {

        expr = metaSlot(expr);

        var op1 = expr.operands[1],
            op2 = expr.operands[2];

        /* expr is  (const|<tmp>) * #1.0  pattern */
        if (expr.operator === '*' && op2 && span(op2[0], '#<') === 1) {
            $$parser.makeMeta(expr, '=ftoi', undefined, undefined, op1, op2);

        } else if (expr.operator === '*' && op1 && span(op1[0], '#<') === 1) {
            $$parser.makeMeta(expr, '=ftoi', undefined, undefined, op2, op1);

        } else {    // generic cast
            $$parser.makeMeta(
                expr, '=ftoi', undefined,
                undefined,
                $$parser.makeRValue(expr),
                '#1.0'
            );
        }
    };

    /* -----------------------------------------------------------
     *  UNARY_OPS dispatch table
     * -------------------------------------------------------- */

    $$parser.UNARY_OPS = {};          /* will hold “=xxx” → handler */

    /* no-op casts */
    function noop() {}

    /* register the handlers */
    map($$parser.UNARY_OPS,
        '=float',     noop,
        '=funcptr',   noop,
        '=int',       noop,
        '=pointer',   noop,

        '=*',         $$parser.dereference,
        '=&',         $$parser.reference,
        '=-',         $$parser.minus,
        '=~',         $$parser.not,
        '=abs',       $$parser.absFloor,
        '=itof',      $$parser.intToFloatConvert,
        '=ftoi',      $$parser.floatToIntConvert,
        '=floor',     $$parser.absFloor
    );

    /* -----------------------------------------------------------
     *  Generic unary operator
     * -------------------------------------------------------- */
    $$parser.unaryOp = function (operator, expr, sourceCode, sourceOffset) {

        expr = metaSlot(expr);

        /* *structPointer → a struct place (through-pointer field access / whole-struct assign) */
        if (operator === '*' && expr.type === 'p' && $$parser.isStructAtom(expr.elem)) {
            $$parser.setPlace(expr, 'pointer', $$parser.makeRValue(expr), 0, expr.elem);
            return;
        }

        /* &structValue → a typed struct pointer (materialize the place's address) */
        if (operator === '&' && expr.place) {
            var structName = expr.struct;
            var addr = $$parser.placeAddress(expr);
            $$parser.makeMeta(expr, ':=', 'p', undefined, addr, undefined);
            $$parser.setElem(expr, structName);
            return;
        }

        var key      = '=' + operator;                // e.g. "=abs"
        var prevType = expr.type;                     /* for element-type propagation (Impala 2) */
        var prevElem = expr.elem;

        /* check type support */
        var sig  = key + expr.type;                   // e.g. "=absf"
        var rTyp = $$parser.SUPPORTED_OPS[ sig ];
        if (rTyp == null) {
            $$parser.typeError('Invalid type ({$type1})',
                               sourceCode, sourceOffset, expr.type, undefined, 'E302');
        }

        /* dispatch actual work */
        var fn = $$parser.UNARY_OPS[ key ];
        if (fn) {
            fn(key, expr, sourceCode, sourceOffset);
        }

        /* update resulting type */
        expr.type = rTyp;

        /* element-type propagation (Impala 2) */
        if (key === '=*') {
            if (prevElem !== undefined) {
                expr.type = $$parser.descHead(prevElem);          /* typed dereference: no cast needed */
                expr.elem = $$parser.descTail(prevElem);
            } else {
                expr.elem = undefined;
            }
        } else if (key === '=&') {
            expr.elem = (prevType === undefined ? undefined       /* &x yields a pointer to x's type */
                    : prevType + (prevElem !== undefined ? ':' + prevElem : ''));
        } else {
            expr.elem = undefined;                                /* casts and numeric ops erase */
        }
    };

    /* -----------------------------------------------------------
     *  Symbol declaration helper
     * -------------------------------------------------------- */

    function $$parser.declare(kind, scope, name, type, readonly, value, sourceCode, sourceOffset, comment, elem) {
        /* emit data / flush pending code */
        if (kind !== undefined) {
            $$parser.flushMetaCode('');

            if (typeof output === 'function') {
                var line = '';
                if (scope === 'locals') line += (typeof TAB !== 'undefined' ? TAB : '\t');
                if (name != null)       line += name + ':';
                line += '\t' +
                        replace(kind, '?', $$parser.TYPE_SUFFIXES[type] || '');
                if (value !== undefined) line += ' ' + value;
                if (comment)             line += '\t; ' + comment;

                output( line );
            }
        }

        /* give any temporary back to the pool */
        $$parser.returnBack(value);

        /* register in symbol table */
        if (name !== undefined) {
            var table = $$parser.symbols[scope];
            var prev  = table && table[name];

            if (prev) {
                if (kind !== undefined && prev.kind !== undefined) {
                    $$parser.fail('Identifier already declared: ' + name,
                                  sourceCode, sourceOffset, 'E401');
                }
                if (type !== prev.type) {
                    $$parser.typeError('Type mismatch with previous declaration of ' +
                                       name + ' (was {$type1})',
                                       sourceCode, sourceOffset, prev.type, undefined, 'E402');
                }
                if (prev.elem !== undefined && elem !== undefined && prev.elem !== elem) {
                    $$parser.fail('Element type mismatch with previous declaration of ' + name
                                  + ' (was ' + $$parser.elemVerbose(prev.elem) + ', now '
                                  + $$parser.elemVerbose(elem) + ')',
                                  sourceCode, sourceOffset, 'E203');
                }
                /* inherit old flags */
                kind     = (kind     !== undefined ? kind     : prev.kind);
                readonly = (readonly || prev.readonly);
                elem     = (elem     !== undefined ? elem     : prev.elem);
            }

            /* store / update */
            if (!table) $$parser.symbols[scope] = table = {};
            table[name] = {
                type: type,
                elem: elem,
                readonly: !!readonly,
                kind: kind,
                signature: prev && prev.signature,
                sourceCode: sourceCode,
                sourceOffset: sourceOffset,
                sourceName: ($$parser.sourceName !== undefined ? $$parser.sourceName
                                                               : (prev ? prev.sourceName : undefined))
            };
        }
    };

    /* -----------------------------------------------------------
     *  Flush all queued meta-code into final text output
     * -------------------------------------------------------- */
    $$parser.flushMetaCode = function (prefix) {

        prefix = prefix || '';
        var TABstr = (typeof TAB !== 'undefined') ? TAB : '\t';

        var nextLabel   = TABstr;   // pending label prefix
        var nextComment = '';       // pending trailing comment
        function formatOperand(op) {
            return (op == null ? '' : op);
        }

        for (var i = 0; i < $$parser.metacode.length; ++i) {

            var rec   = $$parser.metacode[i];
            var op    = rec.operator;

            if (op == null) {
                /* empty / removed meta – skip */
                continue;
            }

            /* -------------------------------------------------- */
            /* handle a stand-alone label (“<--”)                 */
            /* -------------------------------------------------- */
            if (op === '<--') {
                assert(rec.operands[0][0] === '@',
                       "label must start with '@'");
                if (nextLabel !== TABstr) {
                    output(prefix + nextLabel + 'NOOP');
                }
                nextLabel = rec.operands[0].substr(1) + ':' + TABstr;
                continue;
            }

            /* -------------------------------------------------- */
            /* comment pseudo-op (“; …”)                          */
            /* -------------------------------------------------- */
            if (op === ';') {
                nextComment = '\t; ' +
                             replace(rec.operands[0], '\t', ' ');
                continue;
            }

            /* -------------------------------------------------- */
            /* compile-time op (string starts with '<> ')         */
            /* -------------------------------------------------- */
            if (op.substr(0, 3) === '<> ') {

                if (nextLabel !== TABstr) {
                    output(prefix + nextLabel + 'NOOP');
                }
                nextLabel = TABstr;

                var gop = $$parser.META_TO_GAZL[ op.substr(3) ];
                gop      = replace(gop, '?',
                                   $$parser.TYPE_SUFFIXES[ rec.type ]);

                output(prefix + '\t! ' + gop + ' ' +
                       formatOperand(rec.operands[0]) + ' '   +
                       formatOperand(rec.operands[1]) + ' '   +
                       formatOperand(rec.operands[2]) + nextComment);

                nextComment = '';
                continue;
            }

            /* -------------------------------------------------- */
            /* normal run-time instruction                        */
            /* -------------------------------------------------- */
            var gInstr = $$parser.META_TO_GAZL[ op ];
            gInstr     = replace(gInstr, '?',
                                 $$parser.TYPE_SUFFIXES[ rec.type ]);

            output(prefix + nextLabel + gInstr + ' ' +
                   formatOperand(rec.operands[0]) + ' ' +
                   formatOperand(rec.operands[1]) + ' ' +
                   formatOperand(rec.operands[2]) + nextComment);

            nextLabel   = TABstr;
            nextComment = '';
        }

        /* reset queue */
        $$parser.metacode.length = 0;
    };

    /* -----------------------------------------------------------
     *  Identifier lookup helper
     * -------------------------------------------------------- */
    $$parser.lookup = function (x, name, isGlobal, sourceCode, sourceOffset) {

        var sym = $$parser.symbols;
        var p   = null;

        /* local  ------------------------------------------------*/
        if (!isGlobal && (p = sym.locals['$' + name])) {

            if (p.type === 'S') {                                 /* struct value local → a place */
                $$parser.setPlace(x, 'local', '$' + name, 0, p.elem);
                return;
            }
            if (p.type === 'A') {
                $$parser.makeMeta(x, '=&', 'p', undefined,
                                  '$' + name, '*0');
            } else {
                $$parser.makeMeta(x,
                                  (p.readonly ? ':=' : '='),
                                  p.type,
                                  undefined,
                                  '$' + name,
                                  undefined);
            }
            $$parser.setElem(x, p.elem);
            return;
        }

        /* global -----------------------------------------------*/
        if (isGlobal && (p = sym.globals[name])) {

            if (p.type === 'A') {
                $$parser.makeMeta(x, ':=', 'p', undefined,
                                  '&' + name, undefined);
            } else {
                $$parser.makeMeta(x,
                                  (p.readonly ? ':=*' : '=*'),
                                  p.type,
                                  undefined,
                                  '&' + name,
                                  undefined);
            }
            $$parser.setElem(x, p.elem);
            return;
        }

        /* function ---------------------------------------------*/
        if ((p = sym.functions[name])) {
            if (p.type === 'N') {
                $$parser.makeMeta(x, ':=', 'N', undefined,
                                  '^' + name, undefined);
            } else {
                assert(p.type === 'U', 'function entry must be U');
                $$parser.makeMeta(x, ':=', 'F', undefined,
                                  '&' + name, undefined);
            }
            $$parser.setElem(x, undefined);
            return;
        }

        /* constant / #define -----------------------------------*/
        if ((p = sym.defines[name])) {
            $$parser.makeMeta(x, ':=', p.type, undefined,
                              '#' + name, undefined);
            $$parser.setElem(x, p.elem);
            return;
        }

        /* not found --------------------------------------------*/
        $$parser.fail('Undeclared identifier: ' + name,
                      sourceCode, sourceOffset, 'E403');
    };

    /* -----------------------------------------------------------
     *  Ensure expression resolves to a compile-time constant
     * -------------------------------------------------------- */
    $$parser.makeConstant = function (x, wantType,
                                      sourceCode, sourceOffset) {

        var r = $$parser.makeRValue(x, '#<&');

        if (x.type !== wantType ||
            span(r[0], '#<&') !== 1) {

            $$parser.fail(
                bake('Expected constant ' +
                     $$parser.VERBOSE_TYPES[ wantType ]),
                sourceCode, sourceOffset, 'E407');
        }
        return r;
    };

    /* -----------------------------------------------------------
     *  Constant subtraction helper
     * -------------------------------------------------------- */
    $$parser.subConstInt = function (opL, opR) {

        assert(span(opR[0], '#<') === 1,
               "rhs must be const");

        /* trivial cases */
        if (opR === '#0') return opL;

        if (opL[0] === '#' && opR[0] === '#' &&
            span(opL.substr(1), '0123456789') === opL.length - 1 &&
            span(opR.substr(1), '0123456789') === opR.length - 1) {

            return '#' + ( parseInt(opL.substr(1), 10) -
                           parseInt(opR.substr(1), 10) );
        }

        /* need run-time temp */
        $$parser.returnBack(opL);

        var tmp;
        if (span(opL[0], '#<') === 1) {
            $$parser.emit('<> -', 'i',
                          tmp = $$parser.borrow('<'),
                          opL, opR);
        } else {
            $$parser.emit('-', 'i',
                          tmp = $$parser.borrow('%'),
                          opL, opR);
        }
        return tmp;
    };

    /* drop leading “#” helper */
    $$parser.dropHash = function (s) {
        return (s[0] === '#') ? s.substr(1) : s;
    };

    /* printable ASCII table (33–126) */
    $$parser.printable = '';
    for (var i = 33; i < 127; ++i) {
        $$parser.printable += char(i);
    }

    /* -----------------------------------------------------------
     *  Dump a string constant into assembly
     * -------------------------------------------------------- */
    $$parser.dumpString = function (label, str) {

        var len = str.length;
        $$parser.declare('CNST', 'globals', label, '?',
                         true, '*' + len, '', 0);

        var offset = 0;
        while (offset < len) {

            /* raw bytes before printable chunk */
            var non = find(str.substr(offset), $$parser.printable);
            if (non > 0) {
                var d = '';
                for (var k = 0; k < non; ++k) {
                    d += ' #' + ordinal(str[offset + k]);
                }
                $$parser.declare('DATi', undefined, undefined, 'i',
                                 true, d.substr(1), '', 0);
                offset += non;
                continue;
            }

            /* printable (plus spaces) */
            var spanLen = span(str.substr(offset),
                               $$parser.printable + ' ');
            spanLen = rspan(str.substr(offset, spanLen), ' ');
            if (spanLen > 0) {
                $$parser.declare('DATs', undefined, undefined, 'i',
                                 true, str.substr(offset, spanLen), '', 0);
                offset += spanLen;
            }
        }
    };

    /* -----------------------------------------------------------
     *  Manage / share string literals
     * -------------------------------------------------------- */
    $$parser.makeString = function (prefix, x, s,
                                    sourceCode, sourceOffset) {

        s += char(0);       // NUL-terminate

        var byteString = '';
        for (var idx = 0; idx < s.length; ++idx) {
            byteString += char(ordinal(s[idx]));
        }
        s = byteString;

        var tbl = $$parser.strings[prefix];
        if (!tbl) {
            tbl = $$parser.strings[prefix] = [];
            tbl.rlookup = {};
        }

        var entry = tbl.rlookup[s];
        if (entry == null) {

            /* generate unique label */
            var name = '.' + prefix + '_' +
                       (s.replace(/[^0-9a-zA-Z]/g, '')
                          .substr(0, 6)) +
                       '_' +
                       ( (($$parser.randomId + tbl.length) >>> 0)
                         .toString(16) );

            if ($$parser.noForward) {
                $$parser.dumpString(name, s);
            } else {
                tbl.push({ name:name, data:s });
            }

            /* add all suffixes to rlookup */
            for (var k = 0; k < s.length; ++k) {
                tbl.rlookup[ s.substr(k) ] =
                    name + (k ? ':' + k : '');
            }
            entry = name;            // full string label
        }

        $$parser.makeMeta(x, ':=', 'p',
                          undefined, '&' + entry, undefined);
    };

    /* -----------------------------------------------------------
     *  Tiny utilities still missing from the toolbox
     * -------------------------------------------------------- */

    /* wipe an Array or plain Object in-place */
    function prune(o) {
        if (!o) return;
        if (o instanceof Array) {
            o.length = 0;
        } else {
            for (var k in o) {
                delete o[k];
            }
        }
    }

    /* simple “foreach” — fn(element, index) */
    function iterate(arr, fn) {
        for (var i = 0; i < arr.length; ++i) {
            fn(arr[i], i);
        }
    }

    /* -----------------------------------------------------------
     *  Compiler start / end hooks
     * -------------------------------------------------------- */

    $$parser.start = function () {

        /* reset per-compilation state */
        if (!$$parser.stock) $$parser.stock = { '%': [], '<': [] };
        if (!$$parser.counters) $$parser.counters = { '%': 0, '<': 0 };
        if (!$$parser.metacode) $$parser.metacode = [];
        if (!$$parser.symbols) $$parser.symbols = {};
        if (!$$parser.strings) $$parser.strings = { s: [], a: [] };
        if (!$$parser.switchStack) $$parser.switchStack = [];

        /* clear transient pools and counters */
        var poolPercent = $$parser.stock['%'] || ($$parser.stock['%'] = []);
        var poolAngle   = $$parser.stock['<'] || ($$parser.stock['<'] = []);
        resetQueue(poolPercent);
        resetQueue(poolAngle);
        $$parser.counters['%'] = 0;
        $$parser.counters['<'] = 0;

        /* wipe accumulated meta-instructions */
        $$parser.metacode.length = 0;
        $$parser.labelCounter    = 0;
        $$parser.switchStack.length = 0;

        /* reset symbol tables */
        $$parser.symbols.locals   = {};
        $$parser.symbols.globals  = {};
        $$parser.symbols.functions = {};
        $$parser.symbols.defines  = {};
        $$parser.structs          = {};

        /* reset deferred string tables */
        $$parser.strings.s = [];
        $$parser.strings.s.rlookup = {};
        $$parser.strings.a = [];
        $$parser.strings.a.rlookup = {};

        $$parser.noForward = false;

        /* random-id seeding */
        if (typeof hostRandomId !== 'undefined') {
            $$parser.randomId = hostRandomId;
        } else {
            for (var i = 0; i < 1000; ++i) {
                $$parser.randomId =
                    floor(random() * 0xFFFFFFFF) ^ time();
            }
        }

        /* banner */
        var LF = '\n';
        output('; Compiled with Impala version ' +
               $$parser.IMPALA_VERSION + LF);
        output('; signatures version=1');
    };

    $$parser.end = function () {

        /* dump deferred string literals */
        iterate($$parser.strings.s, function (rec) {
            $$parser.dumpString(rec.name, rec.data);
        });

        /* dump assert strings only if present */
        if ($$parser.strings.a.length > 0) {

            output('\t! EQUi #DEBUG #0 @.noAssertStrings');

            iterate($$parser.strings.a, function (rec) {
                $$parser.dumpString(rec.name, rec.data);
            });

            output('.noAssertStrings:\t!');
        }
    };
}

#################
#    Grammar    #
#################

root        <-  _                                                     { $$parser.start(); }
                (FuncDecl / StructDecl / ExternDecl / ConstDecl
                / GlobalDecl / ';'_)* !.                              { $$parser.end(); }

# ------------------------------------------------------------------
#  struct definition
# ------------------------------------------------------------------
StructDecl  <-  STRUCT _ id:Identifier                               { $sname = $id; $$parser.beginStruct($id, $$s, $$i); }
                '{' _
                ( f:(ArrayDecl / VarDecl)                            {
                                                                         $$parser.addStructField($sname,
                                                                             { name: $f.name, type: $f.type, elem: $f.elem,
                                                                               struct: $f.struct, size: $f.size },
                                                                             $$s, $$i);
                                                                     }
                  ( ';' _ )?
                )*
                '}' _                                                { $$parser.endStruct($sname); }

# ------------------------------------------------------------------
#  function declaration                                         
# ------------------------------------------------------------------
FuncDecl    <-  FUNCTION _ id:Identifier '('_                         {
                                                                         assert($$parser.validateStock('%'));
                                                                         assert($$parser.validateStock('<'));

                                                                         output('');
                                                                         output(';-----------------------------------------------------------------------------');

                                                                         /* declare the function symbol */
                                                                         $$parser.declare(
                                                                             undefined,
                                                                             'functions',
                                                                             $id,
                                                                             'U',
                                                                             true,
                                                                             undefined,
                                                                             $$s, $$i
                                                                         );
                                                                         var entry = $$parser.symbols.functions[$id];
                                                                         if (entry) {
                                                                             if (!entry.signature) {
                                                                                 entry.signature = {};
                                                                             }
                                                                             entry.signature.params = [];
                                                                             entry.signature.returns = '?';
                                                                             entry.signature.returnElem = undefined;
                                                                             entry.signature.returnName = undefined;
                                                                             entry.signature.sourceCode = $$s;
                                                                             entry.signature.sourceOffset = $$i;
                                                                             entry.signature.sourceName = $$parser.sourceName;
                                                                             entry.signature.returnResolved = false;
                                                                             entry.pendingReturnPlaceholder = undefined;
                                                                             entry.pendingReturnDeclaration = undefined;
                                                                         }
                                                                     }
inp:ArgsDecl ')'_
(
                    RETURNS _ out:VarDecl                             {
                                                                         var entry = $$parser.symbols.functions[$id];
                                                                         if (entry) {
                                                                             entry.pendingReturnDeclaration = {
                                                                                 name: '$' + $out.name,
                                                                                 type: $out.type,
                                                                                 elem: $out.elem,
                                                                                 size: ($out.size !== undefined ? '*' + $out.size : undefined),
                                                                                 sourceCode: $$s,
                                                                                 sourceOffset: $$i
                                                                             };
                                                                         }
                                                                         if (entry && entry.signature) {
                                                                             entry.signature.returns = $out.type;
                                                                             entry.signature.returnElem = $out.elem;
                                                                             entry.signature.returnName = $out.name;
                                                                             $$parser.resolveFunctionReturnType($id, $out.type, $$s, $$i);
                                                                         }
                                                                     }
                    /
                                                                    {
                                                                        /* implicit 1-word return: even void functions expose
                                                                           a single-word PARA so legacy call sites keep a
                                                                           deterministic return slot and the JSPEG output
                                                                           matches the historical PPEG layout. */
								var entry = $$parser.symbols.functions[$id];
								if (entry) {
									entry.pendingReturnPlaceholder = {
										sourceCode: $$s,
										sourceOffset: $$i
									};
								}
								if (entry && entry.signature) {
									entry.signature.returns = '?';
									entry.signature.returnElem = undefined;
									entry.signature.returnName = undefined;
									$$parser.resolveFunctionReturnType($id, '?', $$s, $$i);
								}
                                                                     }
                )                                                     {
                                                                         /* declare input parameters */
                                                                         var entry = $$parser.symbols.functions[$id];
                                                                         if (entry && entry.signature) {
                                                                             entry.signature.params = [];
                                                                             for (var idx = 0; idx < $inp.n; ++idx) {
                                                                                 var param = $inp[idx];
                                                                                 entry.signature.params.push({
                                                                                     type: param.type,
                                                                                     elem: param.elem,
                                                                                     name: param.name,
                                                                                     size: param.size
                                                                                 });
                                                                             }
                                                                         }
                                                                $$parser.emitFunctionSignature($id);
                                                                if (entry) {
                                                                        if (entry.pendingReturnDeclaration) {
                                                                                var ret = entry.pendingReturnDeclaration;
                                                                                $$parser.declare(
                                                                                        'OUT?', 'locals',
                                                                                        ret.name,
                                                                                        ret.type,
                                                                                        false,
                                                                                        ret.size,
                                                                                        ret.sourceCode,
                                                                                        ret.sourceOffset,
                                                                                        undefined,
                                                                                        ret.elem
                                                                                );
                                                                                entry.pendingReturnDeclaration = undefined;
                                                                        } else if (entry.pendingReturnPlaceholder) {
                                                                                var placeholder = entry.pendingReturnPlaceholder;
                                                                                $$parser.declare(
                                                                                        'PARA', 'locals',
                                                                                        undefined, '?',
                                                                                        false, '*1',
                                                                                        placeholder.sourceCode,
                                                                                        placeholder.sourceOffset
                                                                                );
                                                                                entry.pendingReturnPlaceholder = undefined;
                                                                        }
                                                                }
                                                                         iterate($inp, function (p) {
                                                                             $$parser.declare(
                                                                                 'INP?', 'locals',
                                                                                 '$' + p.name,
                                                                                 p.type,
                                                                                 true,
                                                                                 (p.size !== undefined ? '*' + p.size : undefined),
                                                                                 $$s, $$i,
                                                                                 undefined,
                                                                                 p.elem
                                                                             );
                                                                         });
                                                                     }
                (
                    LOCALS _ loc:LocalsDecl                           {
                                                                         iterate($loc, function (v) {
                                                                             if (v.type === 'S') {         /* struct value local → LOCA *sizeof, remember struct */
                                                                                 $$parser.declare(
                                                                                     'LOCA', 'locals',
                                                                                     '$' + v.name,
                                                                                     'S',
                                                                                     false,
                                                                                     '*' + v.words,
                                                                                     $$s, $$i,
                                                                                     undefined,
                                                                                     v.struct
                                                                                 );
                                                                             } else {
                                                                                 $$parser.declare(
                                                                                     'LOC?', 'locals',
                                                                                     '$' + v.name,
                                                                                     v.type,
                                                                                     false,
                                                                                     (v.size !== undefined ? '*' + v.size : undefined),
                                                                                     $$s, $$i,
                                                                                     undefined,
                                                                                     v.elem
                                                                                 );
                                                                             }
                                                                         });
                                                                     }
                )?                                                    { output(';-----------------------------------------------------------------------------'); }
                Block                                                 {
                                                                         /* wrap-up body */
                                                                         $$parser.processBranches();
                                                                         $$parser.emit('--^', undefined, undefined, undefined, undefined);
                                                                         $$parser.flushMetaCode('\t');

                                                                         prune($$parser.symbols.locals);
                                                                         $$parser.labelCounter = 0;

                                                                         output('');
                                                                     }
ExternDecl  <-  EXTERN _                                              { $$.scope = 'globals'; $$.structFwd = false; }
                (
                    STRUCT _ id:Identifier                            {
                                                                         $$.structFwd = true;
                                                                         $$parser.externStruct($id, $$s, $$i);
                                                                     }
                /   (   FUNCTION                                      { $$.type  = 'U';  $$.scope = 'functions'; }
                    /   NATIVE                                        { $$.type  = 'N';  $$.scope = 'functions'; }
                    ) _ id:Identifier                                 { $$.name  = $id; }
                /                                                     { $desc = undefined; }
                    ( type:BASE_TYPE _                                { $desc = $$parser.CASTS_TO_TYPES[$type]; }
                      ( POINTER _                                     { $desc = 'p:' + $desc; }
                      )*
                    )?
                    ARRAY _ id:Identifier                             {
                                                                         $$.type = 'A';
                                                                         $$.name = $id;
                                                                         $$.elem = $desc;
                                                                     }
                /   VarDecl
                )                                                     {
                                                                        if ($$.structFwd) return true;
                                                                         $$parser.declare(
                                                                             undefined,                 // no section for extern
                                                                             $$.scope,
                                                                             $$.name,
                                                                             $$.type,
                                                                             false,                     // not readonly
                                                                             '?',
                                                                             $$s, $$i,
                                                                             undefined,
                                                                             $$.elem
                                                                         );
                                                                         if ($$.scope === 'functions') {
                                                                             var entry = $$parser.symbols.functions[$$.name];
                                                                             var signature = entry && entry.signature;

                                                                             if (entry) {
                                                                             if (!signature) {
                                                                                 signature = entry.signature = {};
                                                                             }
                                                                             if (signature.sourceName === undefined) {
                                                                                 signature.sourceName = $$parser.sourceName;
                                                                             }
                                                                             if (signature.sourceCode === undefined) {
                                                                                 signature.sourceCode = $$s;
                                                                                 signature.sourceOffset = $$i;
                                                                                 signature.sourceName = $$parser.sourceName;
                                                                             }
                                                                             signature.returnResolved = false;
                                                                        }

                                                                        var role = ($$.type === 'N' ? 'extern native' : 'extern func');
                                                                        var placeholderSignature = {
                                                                            params: [],
                                                                            returns: undefined,
                                                                            sourceName: $$parser.sourceName,
                                                                            sourceCode: $$s,
                                                                            sourceOffset: $$i,
                                                                        };
                                                                        emitStandaloneSignatureComment(
                                                                            $$parser.formatFunctionSignatureComment(
                                                                                $$.name,
                                                                                placeholderSignature,
                                                                                role,
                                                                                $$parser.sourceName,
                                                                                $$s,
                                                                                $$i
                                                                            )
                                                                        );
                                                                         } else if ($$.scope === 'globals') {
                                                                            emitStandaloneSignatureComment(
                                                                                $$parser.formatGlobalSignatureComment(
                                                                                    'GLOB',
                                                                                    $$.name,
                                                                                    $$.type,
                                                                                    $$.size,
                                                                                    'extern',
                                                                                    $$parser.sourceName,
                                                                                    $$s,
                                                                                    $$i,
                                                                                    $$.elem
                                                                                )
                                                                            );
                                                                        }
                                                                    }

ConstDecl   <-  CONST _ type:BASE_TYPE _                              {
                                                                         $desc = $$parser.CASTS_TO_TYPES[$type];
                                                                         $nf = $$parser.noForward;
                                                                         $$parser.noForward = true;
                                                                     }
                 ( POINTER _                                          { $desc = 'p:' + $desc; }
                 )*
                                                                      {
                                                                         $t     = $$parser.descHead($desc);
                                                                         $telem = $$parser.descTail($desc);
                                                                      }
                 id:Identifier
                 (   '=' _ x:Expr                                     {
                                                                            $$parser.declare(
                                                                                '! DEF?', 'defines',
                                                                                $id, $t, true,
                                                                                $$parser.makeConstant($x, $t, $$s, $$i),
                                                                                $$s, $$i,
                                                                                $$parser.formatConstSignatureComment(
                                                                                    $id,
                                                                                    $t,
                                                                                    $$parser.sourceName,
                                                                                    $$s,
                                                                                    $$i,
                                                                                    $telem
                                                                                ),
                                                                                $telem
                                                                            );
                                                                         }
                 /                                                     {
                                                                             $$parser.declare(
                                                                                 undefined, 'defines',
                                                                                 $id, $t, true,
                                                                                 undefined,
                                                                                 $$s, $$i,
                                                                                 undefined,
                                                                                 $telem
                                                                             );
                                                                         }
                 )                                                     { $$parser.noForward = $nf; }

GlobalDecl  <-  (   GLOBAL                                            { $section = 'GLOB'; }
                 /  READONLY                                          { $section = 'CNST'; }
                 /  TEMPORARY                                         { $section = 'TEMP'; }
                 ) _
                 (
                     # primitive variable --------------------------------
                     v:VarDecl                                        {
                                                                             $$parser.declare(
                                                                                 $section, 'globals',
                                                                                 undefined,
                                                                                 $v.type,
                                                                                 ($section === 'CNST'),
                                                                                 '*1',
                                                                                 $$s, $$i
                                                                             );
                                                                             $init = $$parser.ZEROES[$v.type];
                                                                         }
                         ( '=' _ x:Expr                               { $init = $$parser.makeConstant($x, $v.type, $$s, $$i); } )?
                                                                       {
                                                                            $$parser.declare(
                                                                                'DAT?', 'globals',
                                                                                $v.name,
                                                                                $v.type,
                                                                                ($section === 'CNST'),
                                                                                $init,
                                                                                $$s, $$i,
                                                                                $$parser.formatGlobalSignatureComment(
                                                                                    $section,
                                                                                    $v.name,
                                                                                    $v.type,
                                                                                    undefined,
                                                                                    undefined,
                                                                                    $$parser.sourceName,
                                                                                    $$s,
                                                                                    $$i,
                                                                                    $v.elem
                                                                                ),
                                                                                $v.elem
                                                                            );
                                                                         }

                   / # array ----------------------------------------------
                     a:ArrayDecl                                      {
                                                                            $$parser.declare(
                                                                                $section, 'globals',
                                                                                $a.name,
                                                                                'A',
                                                                                ($section === 'CNST'),
                                                                                '*' + $a.size,
                                                                                $$s, $$i,
                                                                                $$parser.formatGlobalSignatureComment(
                                                                                    $section,
                                                                                    $a.name,
                                                                                    'A',
                                                                                    $a.size,
                                                                                    undefined,
                                                                                    $$parser.sourceName,
                                                                                    $$s,
                                                                                    $$i,
                                                                                    $a.elem
                                                                                ),
                                                                                $a.elem
                                                                            );
                                                                         }
                         ( '=' _ d:InitList )?
                 )

# ------------------------------------------------------------------
#  Initialiser list for arrays                                  
# ------------------------------------------------------------------
InitList    <-  '{' _                                                 { $d = ' '; $type = undefined; }
                ( x:Expr                                             {
                                                                            var xMeta = metaSlot($x);
                                                                            $type = xMeta.type;
                                                                            $d += $$parser.makeConstant(xMeta, $type, $$s, $$i);
                                                                        }
                  ( ',' _ x:Expr                                     {
                                                                            var xMeta = metaSlot($x);
                                                                            var xType = xMeta.type;
                                                                            var constant = $$parser.makeConstant(xMeta, xType, $$s, $$i);

                                                                            /* decide if we need to flush DATA */
                                                                            if (  constant[0] === '<'
                                                                              || $d[1] === '<'
                                                                              || ($d + ' ' + constant).length >= 55) {

                                                                                $$parser.declare(
                                                                                    'DATA', 'globals',
                                                                                    undefined, xType,
                                                                                    true, $d.substr(1),
                                                                                    $$s, $$i
                                                                                );
                                                                                $d = '';
                                                                            }
                                                                            $d += ' ' + constant;
                                                                            $type = xType;
                                                                        }
                  )* )?
              '}' _                                                  {
                                                                        if ($d.substr(1) !== '') {
                                                                            $$parser.declare(
                                                                                'DATA', 'globals',
                                                                                undefined, $type,
                                                                                true, $d.substr(1),
                                                                                $$s, $$i
                                                                            );
                                                                        }
                                                                    }

# ------------------------------------------------------------------
#  Parameter & local-variable helper lists                      
# ------------------------------------------------------------------
ArgsDecl    <-                                                        {
                                                                         $$ = [];
                                                                         $$.n = 0;
                                                                     }
                 ( v:VarDecl                                          {
                                                                             var entry = {};
                                                                             entry.type = $v.type;
                                                                             entry.elem = $v.elem;
                                                                             entry.struct = $v.struct;
                                                                             entry.words = $v.words;
                                                                             entry.name = $v.name;
                                                                             entry.size = $v.size;
                                                                             $$[$$.n++] = entry;
                                                                         }
                   ( ',' _ v:VarDecl                                  {
                                                                             var entry = {};
                                                                             entry.type = $v.type;
                                                                             entry.elem = $v.elem;
                                                                             entry.struct = $v.struct;
                                                                             entry.words = $v.words;
                                                                             entry.name = $v.name;
                                                                             entry.size = $v.size;
                                                                             $$[$$.n++] = entry;
                                                                         }
                   )*
                 )?

LocalsDecl  <-                                                        {
                                                                         $$ = [];
                                                                         $$.n = 0;
                                                                     }
                 ( v:(VarDecl / ArrayDecl)                            {
                                                                             var entry = {};
                                                                             entry.type = $v.type;
                                                                             entry.elem = $v.elem;
                                                                             entry.struct = $v.struct;
                                                                             entry.words = $v.words;
                                                                             entry.name = $v.name;
                                                                             entry.size = $v.size;
                                                                             $$[$$.n++] = entry;
                                                                         }
                   ( ',' _ v:(VarDecl / ArrayDecl)                    {
                                                                             var entry = {};
                                                                             entry.type = $v.type;
                                                                             entry.elem = $v.elem;
                                                                             entry.struct = $v.struct;
                                                                             entry.words = $v.words;
                                                                             entry.name = $v.name;
                                                                             entry.size = $v.size;
                                                                             $$[$$.n++] = entry;
                                                                         }
                   )*
                 )?

# ------------------------------------------------------------------
#  Simple variable & array declarators                          
# ------------------------------------------------------------------
# A leading type atom: a primitive keyword, or the name of a defined struct.
TypeBase    <-  t:BASE_TYPE _                                         { $$ = $$parser.CASTS_TO_TYPES[$t]; }
              / id:Identifier                                        {
                                                                         if (!$$parser.isStructAtom($id))
                                                                             $$parser.fail('Unknown type ' + $id, $$s, $$i, 'E413');
                                                                         $$ = $id;
                                                                     }

VarDecl     <-  base:TypeBase                                        { $desc = $base; }
                ( POINTER _                                           { $desc = 'p:' + $desc; }
                )*
                id:Identifier                                         {
                                                                         var head = $$parser.descHead($desc);
                                                                         var tail = $$parser.descTail($desc);
                                                                         if (tail === undefined && $$parser.isStructAtom(head)) {
                                                                             $$.type = 'S';
                                                                             $$.struct = head;
                                                                             $$.elem = undefined;
                                                                             $$.words = $$parser.structWords(head);
                                                                         } else {
                                                                             $$.type = head;
                                                                             $$.elem = tail;
                                                                             $$.struct = undefined;
                                                                             $$.words = undefined;
                                                                         }
                                                                         $$.name = $id;
                                                                         $$.size = undefined;
                                                                     }

ArrayDecl   <-                                                        { $desc = undefined; }
                ( base:TypeBase                                      { $desc = $base; }
                  ( POINTER _                                         { $desc = 'p:' + $desc; }
                  )*
                )?
                ARRAY _ id:Identifier
                '[' _ x:Expr ']' _                                    {
                                                                         $size = $$parser.makeConstant($x, 'i', $$s, $$i);
                                                                         if ($desc !== undefined
                                                                                 && $$parser.descTail($desc) === undefined
                                                                                 && $$parser.isStructAtom($$parser.descHead($desc)))
                                                                             $$parser.fail('Arrays of struct values are not yet supported'
                                                                                     + ' (use a pointer element)', $$s, $$i, 'E414');
                                                                         $$.type = 'A';
                                                                         $$.elem = $desc;
                                                                         $$.name = $id;
                                                                         $$.size = $$parser.dropHash($size);
                                                                         $$parser.returnBack($size);
                                                                     }

# ------------------------------------------------------------------
#  Statement rule dispatch                                      
# ------------------------------------------------------------------
Statement   <-                                                        {
                                                                         var snippet = $$s.substr($$i);
                                                                         var cut     = find(snippet, "{;\r\n");
                                                                         var txt     = (cut >= 0 ? snippet.substr(0, cut)
                                                                                              : snippet);
                                                                         $$parser.emitMeta({ operator:';', type:undefined,
                                                                                            operands:[ txt, undefined, undefined ] });
                                                                     }
                (
                    label:Identifier ':' _                            {
                                                                            $$parser.emitMeta({ operator:'<--', type:undefined,
                                                                                                operands:[ '@' + $label._, undefined, undefined ] });
                                                                        }
                )*
                (   ';' _
                /   Assert
                /   Block
                /   Copy
                /   DoWhile
                /   Loop
                /   For
                /   Goto
                /   If
                /   Switch
                /   While
                /   Expr ';' _                                        { $$parser.releaseMeta($$); }
                )

Expr        <-  Bitwise ('='_ r:Expr               { if (!$$parser.dry)
                                                       $$parser.assign($$, $$, $r, $$s, $$i); }
                )?

Bitwise     <-                                     { $first = undefined; }
                AddSub (op:BITWISE_OP _ r:AddSub   { if (!$$parser.dry) {
                                                       if ($first === undefined) $first = $op;
                                                       else if ($first !== $op)
                                                           $$parser.mixedBitwise($first, $op, $$s, $$i);
                                                       $$parser.binaryOp($op, $$, $r, $$s, $$i);
                                                     } }
                )*                                 { if (!$$parser.dry)
                                                       $$parser.stampBitwise($$, $first !== undefined); }

AddSub      <-  MulDiv (op:ADDSUB_OP _ r:MulDiv    { if (!$$parser.dry)
                                                       $$parser.binaryOp($op, $$, $r, $$s, $$i); }
                )*

MulDiv      <-  PrePost (op:MULDIV_OP _ r:PrePost  { if (!$$parser.dry)
                                                       $$parser.mulDivOp($op, $$, $r, $$s, $$i); }
                )*

PrePost     <-  (op:PREFIX_OP _
                / '('_ op:BASE_TYPE _               { $cdesc = $$parser.CASTS_TO_TYPES[$op]; }
                  ( POINTER _                       { $cdesc = 'p:' + $cdesc; $cmods = true; }
                  )* ')'_
                / '('_ sid:Identifier               { $pdepth = 0; }   # struct-pointer cast: (Name pointer …)
                  ( POINTER _                       { $pdepth = $pdepth + 1; }
                  )+ ')'_                           {
                                                      if (!$$parser.isStructAtom($sid))
                                                          $$parser.fail('Unknown type ' + $sid, $$s, $$i, 'E413');
                                                      $cdesc = $sid;
                                                      for (var _pk = 0; _pk < $pdepth; ++_pk) $cdesc = 'p:' + $cdesc;
                                                      $cmods = true;
                                                    }
                ) PrePost                           { if (!$$parser.dry) {
                                                       if ($cmods) {
                                                           $$parser.unaryOp('pointer', $$, $$s, $$i);
                                                           $$parser.setElem($$, $$parser.descTail($cdesc));
                                                       } else {
                                                           $$parser.unaryOp($op, $$, $$s, $$i);
                                                       }
                                                     } }
                / Value (FuncCall / Subscript / FieldAccess)*

Subscript   <-  '['_ s:Expr ']'_                   { if (!$$parser.dry)
                                                       $$parser.binaryOp('=[]', $$, $s, $$s, $$i); }

FieldAccess <-  '->'_ f:Identifier                 { if (!$$parser.dry)
                                                       $$parser.fieldAccess($$, $f, true, $$s, $$i); }
                / '.'_ f:Identifier                { if (!$$parser.dry)
                                                       $$parser.fieldAccess($$, $f, false, $$s, $$i); }

FuncCall    <-  '('_                               { if (!$$parser.dry) {
                                                       $$.count = 0;
                                                       $$.base  = $$parser.borrowForCall();
                                                       $$.types = [];
                                                       $$.elems = [];
                                                       $$.nulls = [];
                                                    } }
                (Argument (','_ Argument)*)? ')'_  { if (!$$parser.dry) {
                                                       var callee = metaSlot($$);
                                                       var callResultType = '?';
                                                       var signature = null;
                                                       var calleeName = null;

                                                       if (span(callee.type, 'FN') !== 1) {
                                                           $$parser.typeError(
                                                               'Invalid type for function call ({$type1})',
                                                               $$s, $$i, callee.type
                                                           , undefined, 'E408');
                                                       }

                                                       if (callee.operator === ':=' &&
                                                           callee.operands[1] &&
                                                           (callee.operands[1][0] === '&' ||
                                                            callee.operands[1][0] === '^')) {
                                                           calleeName = callee.operands[1].substr(1);
                                                           var entry = $$parser.symbols.functions[calleeName];
                                                           if (entry && entry.kind === 'FUNC' && entry.signature) {
                                                               signature = entry.signature;
                                                           }
                                                       }

                                                       if (signature) {
                                                           var params = signature.params || [];
                                                           var actualCount = ($$.types ? $$.types.length : 0);
                                                           var expectedCount = params.length;
                                                           var label = (calleeName || 'function');

                                                           if (actualCount !== expectedCount) {
                                                               $$parser.fail(
                                                                   'Invalid argument count when calling ' + label +
                                                                   ' (expected ' + expectedCount + ', got ' + actualCount + ')',
                                                                   $$s, $$i
                                                               , 'E405');
                                                           }

                                                           for (var argIdx = 0; argIdx < expectedCount; ++argIdx) {
                                                               var expected = params[argIdx].type;
                                                               var actual = $$.types[argIdx];
                                                               if (actual === undefined) {
                                                                   actual = '?';
                                                               }
                                                               if (actual === '?' || expected === undefined) {
                                                                   continue;
                                                               }
                                                               if (actual !== expected) {
                                                                   $$parser.typeError(
                                                                       'Argument type mismatch when calling ' + label +
                                                                           ' ({$type1} vs expected {$type2})',
                                                                       $$s, $$i,
                                                                       actual,
                                                                       expected
                                                                   , 'E406');
                                                               }
                                                               var expectedElem = params[argIdx].elem;   /* typed pointer param: assume loudly */
                                                               if (expected === 'p' && expectedElem !== undefined
                                                                       && !$$.nulls[argIdx]
                                                                       && $$.elems[argIdx] !== expectedElem) {
                                                                   $$parser.fail('Pointer element type mismatch for argument '
                                                                           + (argIdx + 1) + ' when calling ' + label
                                                                           + ' (expected ' + $$parser.elemVerbose(expectedElem)
                                                                           + ' elements, got ' + $$parser.elemVerbose($$.elems[argIdx])
                                                                           + ' elements)', $$s, $$i, 'E202',
                                                                           'use a cast: (' + $$parser.elemVerbose(expectedElem) + ' pointer)');
                                                               }
                                                           }

                                                           if (signature.returnResolved &&
                                                               signature.returns !== undefined) {
                                                               callResultType = signature.returns;
                                                           } else if (signature.expectedReturn !== undefined) {
                                                               callResultType = signature.expectedReturn;
                                                           } else if (signature.returns !== undefined) {
                                                               callResultType = signature.returns;
                                                           }
                                                       }

                                                       var callComment = $$parser.formatCallExpectationComment(
                                                           calleeName,
                                                           signature,
                                                           $$.types,
                                                           callResultType,
                                                           $$parser.sourceName,
                                                           $$s,
                                                           $$i
                                                       );
                                                       var commentIndex = -1;
                                                       if (callComment) {
                                                           commentIndex = $$parser.metacode.length;
                                                           $$parser.emit(';', undefined, callComment, undefined, undefined);
                                                           commentIndex = $$parser.metacode.length - 1;
                                                       }

                                                       var func = $$parser.makeRValue(callee, '&^$%');
                                                       $$parser.emit('()', '?',
                                                                     func,
                                                                     '%' + $$.base,
                                                                     '*' + ($$.count + 1));
                                                       $$parser.returnBack(func);

                                                       while ($$.count-- > 0) {
                                                           $$parser.returnBack('%' + ($$.base + $$.count + 1));
                                                       }

                                                       $$parser.makeMeta(callee, ':=', callResultType,
                                                                         undefined,
                                                                         '%' + $$.base,
                                                                         undefined);
                                                       $$parser.setElem(callee, undefined);

                                                       if (calleeName) {
                                                           callee.callInfo = {
                                                               name: calleeName,
                                                               commentIndex: commentIndex,
                                                               commentArgs: {
                                                                   name: calleeName,
                                                                   signature: signature,
                                                                   actualTypes: ($$.types ? $$.types.slice() : undefined),
                                                                   sourceName: $$parser.sourceName,
                                                                   sourceCode: $$s,
                                                                   sourceOffset: $$i
                                                               }
                                                           };
                                                       } else if (callee.callInfo) {
                                                           callee.callInfo = undefined;
                                                       }
                                                    } }

Argument    <-  a:Expr                             { if (!$$parser.dry) {
                                                       ++$$.count;
                                                       var meta = metaSlot($a);
                                                       if ($$.types) {
                                                           $$.types.push(meta.type);
                                                       }
                                                       if ($$.elems) {                       /* element chain + null-ness, captured */
                                                           $$.elems.push(meta.elem);         /* before makeArgValue mutates the meta */
                                                           $$.nulls.push(meta.type === 'p'
                                                               && meta.operands[1] === '&NULL'
                                                               && meta.operands[2] === undefined);
                                                       }
                                                       $$parser.makeArgValue($a, $$.base + $$.count);
                                                    } }

Group       <-  '('_ Expr ')'_                      { if (!$$parser.dry)
                                                        $$parser.stampBitwise($$, false); }


BoolGroup   <-  '('_                                { $label = undefined; }
                And ('||'_                          { 
                                                        if ($label === undefined) { 
                                                            $label = $$parser.newLabel('t'); 
                                                        }
                                                        $$parser.emit('?->', true, $label, undefined, undefined); 
                                                    }
                And)* ')'_                          { 
                                                        if ($label !== undefined) { 
                                                            $$parser.emit('<-?', true, $label, undefined, undefined); 
                                                        } 
                                                    }


And         <-                                      { $label = undefined; }
                Comp ('&&'_                         { 
                                                        if ($label === undefined) { 
                                                            $label = $$parser.newLabel('f'); 
                                                        }
                                                        $$parser.emit('?->', false, $label, undefined, undefined); 
                                                    }
                Comp)*                              { 
                                                        if ($label !== undefined) { 
                                                            $$parser.emit('<-?', false, $label, undefined, undefined); 
                                                        } 
                                                    }


Comp        <-  '!'_ Comp                           { 
                                                        $$parser.emit('!', undefined, undefined, undefined, undefined); 
                                                    }
                /                                   { $$parser.dry = true; }
                    !Group                          { $$parser.dry = false; }
                    BoolGroup
                /                                   { $$parser.dry = false; }
                    Expr op:COMP_OP _ r:Expr        {
                                                        $$parser.checkCompMix($$, $r, $$s, $$i);
                                                        $$parser.binaryOp($op, $$, $r, $$s, $$i);
                                                        $$parser.emitMeta($$);
                                                        $$parser.releaseMeta($$);
                                                    }


Assert      <-  ASSERT _                            {
                                                        $okLabel = $$parser.newLabel('a');
                                                        $$parser.emit('<> ==', 'i', '#DEBUG', '#0', $okLabel);
                                                        $start    = $$i;
                                                        $exprText = '';
                                                    }
                str:BoolGroup                       {
                                                        $exprText = $$s.substring($start, $$i);
                                                        $exprText = $exprText.replace(/[ \t\r\n]+$/, '');
                                                    }
                ';'_                                {
                                                        $$parser.emit('?->', true, $okLabel, undefined, undefined);

                                                        var r = $$parser.borrowForCall();

                                                        /* store the assert-string constant */
                                                        $$parser.makeString('a', $str, $exprText, $$s, $$i);

                                                        /* argument goes into %<r+1> */
                                                        $$parser.makeArgValue($str, r + 1);

                                                        /* call the failure handler */
                                                        $$parser.emit('()', '?', '^assertFail',
                                                                      '%' + r, '*1');

                                                        /* tidy temporaries */
                                                        $$parser.returnBack('%' + (r + 1));
                                                        $$parser.returnBack('%' +  r);

                                                        /* continue after OK-label */
                                                        $$parser.emit('<-?', true, $okLabel, undefined, undefined);
                                                    }


Block       <-  '{'_ Statement* '}'_


Goto        <-  GOTO _ label:Identifier ';'_        {
                                                        $$parser.emit('-->', undefined, '@' + $label._, undefined, undefined);
                                                    }


# TODO : if full jump-optimisation is implemented we could always
#        fold the “empty else” block here.
If          <-  IF _ BoolGroup                      { 
                                                        $dontLabel = $$parser.newLabel('f');
                                                        $$parser.emit('?->', false, $dontLabel, undefined, undefined); 
                                                    }
                Statement (ELSE _                   { 
                                                        $doneLabel = $$parser.newLabel('e');
                                                        $$parser.emit('-->', undefined, $doneLabel, undefined, undefined);
                                                        $$parser.emit('<-?',  false, $dontLabel, undefined, undefined); 
                                                    }
                Statement                           { 
                                                        $$parser.emit('<--', undefined, $doneLabel, undefined, undefined); 
                                                    }
                /                                   { 
                                                        $$parser.emit('<-?', false, $dontLabel, undefined, undefined); 
                                                    }
                )


DoWhile     <-  DO _                                { 
                                                        $loopLabel = $$parser.newLabel('l');
                                                        $$parser.emit('<-?', false, $loopLabel, undefined, undefined); 
                                                    }
                Statement
                WHILE _ BoolGroup                   { 
                                                        $$parser.emit('?->', true, $loopLabel, undefined, undefined); 
                                                    }


Loop        <-  LOOP _                              { 
                                                        $loopLabel = $$parser.newLabel('l');
                                                        $$parser.emit('<--', undefined, $loopLabel, undefined, undefined); 
                                                    }
                Statement                           { 
                                                        $$parser.emit('-->', undefined, $loopLabel, undefined, undefined); 
                                                    }

# ---------------------------------------------------------------------------
#   FOR … TO … loop
# ---------------------------------------------------------------------------
For         <-  FOR _ '('_ var:Variable             {
                                                        /* loop-variable must be local, modifiable int / pointer */
                                                        var varMeta = metaSlot($var);
                                                        if (varMeta.operator !== '=' || span(varMeta.type, "ip") === 0) {
                                                            $$parser.fail(
                                                                'For variable must be a local modifiable int or pointer variable',
                                                                $$s, $$i
                                                            , 'E305');
                                                        }
                                                        $gotInit = false;            /* flag to detect an explicit start value */
                                                    }
                ('='_ init:Expr                     {
                                                        $$parser.assign($init, $var, $init, $$s, $$i);
                                                        $gotInit = true;
                                                    }
                )? TO _ toExpr:Expr ')'_            {
                                                        var varMeta  = metaSlot($var);
                                                        var toMeta   = metaSlot($toExpr);

                                                        if (toMeta.type !== varMeta.type) {
                                                            $$parser.typeError(
                                                                'Incompatible types ({$type1} and {$type2})',
                                                                $$s, $$i, varMeta.type, toMeta.type
                                                            , 'E301');
                                                        }

                                                        /* constant upper bound */
                                                        $to = $$parser.makeRValue(toMeta);

                                                        /* initial comparison  (var < to)                         */
                                                        $$parser.emit(
                                                            '<',
                                                            toMeta.type,
                                                            undefined,
                                                            $gotInit ? metaSlot($init).operands[1]     /* start value from “var = expr” */
                                                                     : varMeta.operands[1],            /* or the original variable */
                                                            $to
                                                        );

                                                        if ($gotInit) {
                                                            $$parser.releaseMeta($init);
                                                        }

                                                        /* branch-out   and  loop label */
                                                        $noLoopLabel = $$parser.newLabel('e');
                                                        $$parser.emit('?->', false, $noLoopLabel, undefined, undefined);

                                                        $loopLabel   = $$parser.newLabel('l');
                                                        $$parser.emit('<--', undefined, $loopLabel, undefined, undefined);
                                                    }
                body:Statement                      {
                                                        var varMeta = metaSlot($var);

                                                        /* increment + jump back */
                                                        $$parser.emit(
                                                            '...',
                                                            varMeta.type,
                                                            varMeta.operands[1],        /* address of loop variable */
                                                            $to,
                                                            $loopLabel
                                                        );
                                                        $$parser.emit('<-?', false, $noLoopLabel, undefined, undefined);

                                                        $$parser.returnBack($to);
                                                        $$parser.releaseMeta(varMeta);
                                                    }

# ---------------------------------------------------------------------------
#   COPY (len) FROM src TO dst
# ---------------------------------------------------------------------------
Copy        <-  COPY _ '('_ l:Expr FROM _ f:Expr TO _ t:Expr ')' _
                                                    {
                                                        var fromMeta = metaSlot($f);
                                                        var toMeta   = metaSlot($t);

                                                        $length = $$parser.makeConstant($l, 'i', $$s, $$i);
                                                        var lengthHash = $$parser.dropHash($length);

                                                        if (fromMeta.type + toMeta.type !== 'pp') {
                                                            $$parser.returnBack($length);
                                                            $$parser.typeError(
                                                                'Invalid types ({$type1} and {$type2})',
                                                                $$s, $$i, fromMeta.type, toMeta.type
                                                            , 'E301');
                                                        }

                                                        var copyMeta = metaSlot($l);
                                                        $$parser.makeMeta(
                                                            copyMeta,
                                                            'copy',
                                                            '?',
                                                            $$parser.makeRValue(toMeta, '&$%'),
                                                            $$parser.makeRValue(fromMeta, '&$%'),
                                                            '*' + lengthHash
                                                        );

                                                        $$parser.emitMeta(copyMeta);
                                                        $$parser.returnBack($length);
                                                        $$parser.releaseMeta(copyMeta);
                                                    }

# ---------------------------------------------------------------------------
#   SWITCH (expr == from TO to) { … }
# ---------------------------------------------------------------------------
Switch      <-  SWITCH _ '('_ $$:Expr
                '=='_ f:Expr TO _ t:Expr    {
                                                        var switchMeta = metaSlot($$);

                                                        /* the switch expression must be an int */
                                                        if (switchMeta.type !== 'i') {
                                                            $$parser.fail('Switch expression needs to be int', $$s, $$i, 'E306');
                                                        }

                                                        /* lower bound (compile-time constant) */
                                                        switchMeta.from = $$parser.makeConstant($f, 'i', $$s, $$i);

                                                        /*    size = to - from   */
                                                        $size = $$parser.subConstInt(
                                                                     $$parser.makeConstant($t, 'i', $$s, $$i),
                                                                     switchMeta.from
                                                                 );

                                                        /*   switcher = (expr − from)   */
                                                        $switcher = $$parser.subConstInt(
                                                                         $$parser.makeRValue(switchMeta, '$%'),
                                                                         switchMeta.from
                                                                     );

                                                        switchMeta.switchLabel = $$parser.newLabel('s');
                                                        $switchExit              = $$parser.newLabel('e');

                                                        $$parser.switchStack.push(switchMeta);

                                                        $$parser.emit(
                                                            '-->#',
                                                            switchMeta.type,
                                                            $switcher,
                                                            '*' + $$parser.dropHash($size),
                                                            switchMeta.switchLabel
                                                        );

                                                        $$parser.returnBack($switcher);
                                                        $$parser.returnBack($size);

                                                        $progress = undefined;       /* track case / default presence */
                                                    }
                ')'_ '{'_
                (
                    ( CASE _                        {
                                                            /* multiple CASE groups → fall-through handled here */
                                                            if ($progress !== undefined) {
                                                                $$parser.emit('-->', undefined, $switchExit, undefined, undefined);
                                                            } else {
                                                                $progress = 'gotCases';
                                                            }

                                                            /* dump the literal “case …” comment */
                                                            var snippet = $$s.substr($$i);
                                                            var pos     = find(snippet, ":\r\n");
                                                            if (pos >= 0) {
                                                                snippet = snippet.substr(0, pos);
                                                            }
                                                            $$parser.emit(
                                                                ';', undefined,
                                                                'case ' + snippet,
                                                                undefined, undefined
                                                            );
                                                        }
                      CaseExpr
                      (','_ CaseExpr)*
                    / DEFAULT _                     {
                                                            if ($progress === 'gotDefault') {
                                                                $$parser.fail('Default case already defined', undefined, undefined, 'E409');
                                                            } else if ($progress !== undefined) {
                                                                $$parser.emit('-->', undefined, $switchExit, undefined, undefined);
                                                            }

                                                            var ctx = $$parser.switchStack[$$parser.switchStack.length - 1];

                                                            $$parser.emit(';',    undefined, 'default',       undefined, undefined);
                                                            $$parser.emit('<--',  undefined, ctx.switchLabel,  undefined, undefined);
                                                            $progress = 'gotDefault';
                                                        }
                    ) ':'_ stmt:Statement
                )*
                '}'_                                {
                                                        var ctx = $$parser.switchStack.pop() || metaSlot($$);

                                                        /* no explicit “default” → hook it up now                        */
                                                        if ($progress !== 'gotDefault') {
                                                            $$parser.emit('<--', undefined, ctx.switchLabel, undefined, undefined);
                                                        }
                                                        $$parser.emit('<--', undefined, $switchExit, undefined, undefined);

                                                        $$parser.returnBack(ctx.from);
                                                    }

# ---------------------------------------------------------------------------
#   single “case …” inside a switch
# ---------------------------------------------------------------------------
CaseExpr    <-  Expr                                {
                                                        /* offset = constant(expr) – switch.from                         */
                                                        var ctx      = $$parser.switchStack[$$parser.switchStack.length - 1];
                                                        var caseMeta = metaSlot($$);
                                                        var baseFrom = (ctx ? ctx.from : caseMeta.from);
                                                        var baseLabel = (ctx ? ctx.switchLabel : caseMeta.switchLabel);

                                                        $n = $$parser.subConstInt(
                                                                $$parser.makeConstant(caseMeta, 'i', $$s, $$i),
                                                                baseFrom
                                                            );

                                                        /* create label for this case                                     */
                                                        $$parser.emit(
                                                            '<--',
                                                            undefined,
                                                            baseLabel + '#' + $$parser.dropHash($n),
                                                            undefined, undefined
                                                        );

                                                        $$parser.returnBack($n);
                                                    }

# ---------------------------------------------------------------------------
#   WHILE  condition  statement
# ---------------------------------------------------------------------------
While       <-  WHILE _                             {
                                                        $loopLabel = $$parser.newLabel('l');
                                                        $$parser.emit('<--', undefined, $loopLabel, undefined, undefined);
                                                    }
                BoolGroup                           {
                                                        $exitLabel = $$parser.newLabel('e');
                                                        $$parser.emit('?->', false, $exitLabel, undefined, undefined);
                                                    }
                Statement                           {
                                                        $$parser.emit('-->', undefined, $loopLabel, undefined, undefined);
                                                        $$parser.emit('<-?', false, $exitLabel, undefined, undefined);
                                                    }

# ---------------------------------------------------------------------------
#   atomic values
# ---------------------------------------------------------------------------
Value       <-  Group
                / SIZEOF _ '('_ base:TypeBase        { if (!$$parser.dry) {
                                                        var head = $$parser.descHead($base);
                                                        var words = ($$parser.isStructAtom(head)
                                                                ? $$parser.structWords(head) : 1);
                                                        if (words === undefined)
                                                            $$parser.fail('sizeof of incomplete struct ' + head,
                                                                    $$s, $$i, 'E419');
                                                        $$parser.makeMeta($$, ':=', 'i', undefined, '#' + words, undefined);
                                                        $$parser.setElem($$, undefined);
                                                      } } ')'_
                / f:FloatLiteral                    { if (!$$parser.dry) {
                                                        $$parser.makeMeta($$, ':=', 'f', undefined, '#' + $f, undefined);
                                                        $$parser.setElem($$, undefined);
                                                      } }
                / i:IntegerLiteral                  { if (!$$parser.dry) {
                                                        $$parser.makeMeta($$, ':=', 'i', undefined, '#' + $i, undefined);
                                                        $$parser.setElem($$, undefined);
                                                      } }
                / s:StringLiteral                   { if (!$$parser.dry) {
                                                        $$parser.makeString('s', $$, evaluate($s), $$s, $$i);
                                                        $$parser.setElem($$, 'i');      /* string data is int words (Impala 2) */
                                                      } }
                / NULL _                            { if (!$$parser.dry) {
                                                        $$parser.makeMeta($$, ':=', 'p', undefined, '&NULL', undefined);
                                                        $$parser.setElem($$, undefined);
                                                      } }
                / NULLFUNC _                        { if (!$$parser.dry) {
                                                        $$parser.makeMeta($$, ':=', 'F', undefined, '&NULL', undefined);
                                                        $$parser.setElem($$, undefined);
                                                      } }
                / Variable

# ---------------------------------------------------------------------------
#   identifiers, optionally prefixed with “global”
# ---------------------------------------------------------------------------
Variable    <-                                      { $global = false; }
                (GLOBAL _                           { $global = true; }
                )?
                id:Identifier                       { if (!$$parser.dry) {
                                                        $$parser.lookup($$, $id, $global, $$s, $$i);
                                                      } }


########################
#    Lexical Syntax    #
########################

Identifier      <-  !KEYWORD $$=([A-Za-z_$] SYMBOL_CHAR*) _
FloatLiteral    <-  $$=([-+]? DIGIT+ "." DIGIT+ (("E" / "e") ([-+]? DIGIT+))?) _
IntegerLiteral  <-  $$=([-+]? ("0x" HEX+ / "'" (!"'" ASCII)* "'" / DIGIT+)) _
StringLiteral   <-  $$=( '"' ( !["\\\0-\37] . / "\\" ( [\"\\bfnrt] / 'u' HEX HEX HEX HEX ) )* '"' ) _

KEYWORD     <-  ABS / ARRAY / ASSERT / CASE / CONST / COPY / DEFAULT / DO / ELSE / EXTERN / FLOAT / FLOOR / FOR / FROM
                / FTOI / FUNCPTR / FUNCTION / GLOBAL / GOTO / IF / INT / ITOF / LOCALS / LOOP / NATIVE / NULL / NULLFUNC
                / POINTER / READONLY / RETURNS / SIZEOF / STRUCT / SWITCH / TEMPORARY / TO / WHILE

ABS         <-  'abs' !SYMBOL_CHAR          ARRAY       <-  'array' !SYMBOL_CHAR
ASSERT      <-  'assert' !SYMBOL_CHAR       CASE        <-  'case' !SYMBOL_CHAR
CONST       <-  'const' !SYMBOL_CHAR        COPY        <-  'copy' !SYMBOL_CHAR
DEFAULT     <-  'default' !SYMBOL_CHAR
DO          <-  'do' !SYMBOL_CHAR           ELSE        <-  'else' !SYMBOL_CHAR
EXTERN      <-  'extern' !SYMBOL_CHAR       FLOAT       <-  'float' !SYMBOL_CHAR
FLOOR       <-  'floor' !SYMBOL_CHAR        FOR         <-  'for' !SYMBOL_CHAR
FROM        <-  'from' !SYMBOL_CHAR
FTOI        <-  'ftoi' !SYMBOL_CHAR         FUNCPTR     <-  'funcptr' !SYMBOL_CHAR
FUNCTION    <-  'function' !SYMBOL_CHAR     GLOBAL      <-  'global' !SYMBOL_CHAR
GOTO        <-  'goto' !SYMBOL_CHAR         IF          <-  'if' !SYMBOL_CHAR
INT         <-  'int' !SYMBOL_CHAR          ITOF        <-  'itof' !SYMBOL_CHAR
LOCALS      <-  'locals' !SYMBOL_CHAR       LOOP        <-  'loop' !SYMBOL_CHAR
NATIVE      <-  'native' !SYMBOL_CHAR       NULL        <-  'null' !SYMBOL_CHAR
NULLFUNC    <-  'nullfunc' !SYMBOL_CHAR
POINTER     <-  'pointer' !SYMBOL_CHAR      READONLY    <-  'readonly' !SYMBOL_CHAR
RETURNS     <-  'returns' !SYMBOL_CHAR      SWITCH      <-  'switch' !SYMBOL_CHAR
SIZEOF      <-  'sizeof' !SYMBOL_CHAR       STRUCT      <-  'struct' !SYMBOL_CHAR
TEMPORARY   <-  'temporary' !SYMBOL_CHAR    TO          <-  'to' !SYMBOL_CHAR
WHILE       <-  'while' !SYMBOL_CHAR

BITWISE_OP  <-  $$=( '<<' / '>>>' / '>>' / '|' !'|' / '&' !'&' / '^' )
ADDSUB_OP   <-  $$=( '+' / '-' )
MULDIV_OP   <-  $$=( '*' / '/' !'/' / '%' )
COMP_OP     <-  $$=( '<=' / '>=' / '!=' / '==' / '<' / '>' )
BASE_TYPE   <-  INT                               { $._ = 'int'; }
            /  FLOAT                              { $._ = 'float'; }
            /  FUNCPTR                            { $._ = 'funcptr'; }
            /  POINTER                            { $._ = 'pointer'; }
BUILT_IN    <-  $$=( 'abs' / 'floor' / 'itof' / 'ftoi' )
PREFIX_OP   <-  $$=( '-' !("'" / DIGIT)
                   / '~'
                   / '&'
                   / '*'
                   / BUILT_IN !SYMBOL_CHAR
                 )
SYMBOL_CHAR <-  [A-Za-z_$0-9]
HEX         <-  [0-9A-Fa-f]
DIGIT       <-  [0-9]
ASCII       <-  ![\0-\37] .
_           <-  ([ \t\r\n]+ / COMMENT)*
COMMENT     <-  '/*' (!'*/' .)* '*/' / "//" (![\r\n] .)*
