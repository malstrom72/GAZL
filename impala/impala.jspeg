                    ? head : signatureParamCategory(head));
        }
        if ($$parser.isArrayAtom(head)) {                         /* array-shape level: "<elem>-array-4x5" */
            return signatureCategoryForDesc(tail) + '-array-' + $$parser.arrayAtomDims(head).join('x');
