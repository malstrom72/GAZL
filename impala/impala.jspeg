                                                                         $$.size = undefined;
                                                                     }

ArrayDecl   <-                                                        { $desc = undefined; $dims = []; }
                ( base:TypeBase                                      { $desc = $base; }
                  ( POINTER _                                         { $desc = 'p:' + $desc; }
                  )*
                )?
                ARRAY _ id:Identifier
                ( '[' _ x:Expr ']' _                                  {   /* one or more dimensions: a[H], a[H, W], ... (comma form is one bracket, handled below) */
                                                                         var _sz = $$parser.makeConstant($x, 'i', $$s, $$i);
                                                                         $dims.push($$parser.dropHash(_sz));
                                                                         $$parser.returnBack(_sz);
                                                                     }
                / '[' _ x:Expr                                        {   /* comma-separated dimensions: a[H, W, ...] */
                                                                         var _sz0 = $$parser.makeConstant($x, 'i', $$s, $$i);
                                                                         $dims.push($$parser.dropHash(_sz0));
                                                                         $$parser.returnBack(_sz0);
                                                                     }
                  ( ',' _ x:Expr                                      {
                                                                         var _szn = $$parser.makeConstant($x, 'i', $$s, $$i);
                                                                         $dims.push($$parser.dropHash(_szn));
                                                                         $$parser.returnBack(_szn);
                                                                     }
                  )+ ']' _
                )                                                     {
                                                                         $$.type = 'A';
                                                                         $$.elem = $desc;
                                                                         $$.name = $id;
                                                                         $$.dims = $dims;
                                                                         /* allocation words = (product of dimensions) * element size (structs are multi-word) */
                                                                         var _isStructEl = ($desc !== undefined
                                                                                 && $$parser.descTail($desc) === undefined
                                                                                 && $$parser.isStructAtom($$parser.descHead($desc)));
                                                                         var _ew = _isStructEl ? $$parser.structWords($$parser.descHead($desc)) : 1;
                                                                         var _count = 1;
                                                                         for (var _di = 0; _di < $dims.length; ++_di) {
                                                                             if (!/^[0-9]+$/.test('' + $dims[_di]) && (_isStructEl || $dims.length > 1))
                                                                                 $$parser.fail('An array dimension must be a numeric literal for now',
                                                                                         $$s, $$i, 'E414');
