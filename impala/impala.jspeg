FieldAccess <-  '->'_ f:Identifier                 { if (!$$parser.dry)
                                                       $$parser.fieldAccess($$, $f, true, $$s, $$i); }
                / '.'_ f:Identifier                { if (!$$parser.dry)
                                                       $$parser.fieldAccess($$, $f, false, $$s, $$i); }

FuncCall    <-  '('_                               { if (!$$parser.dry) {
                                                       $$.count = 0;
                                                       /* how many leading output slots the callee expects (>1 = multi-return) */
                                                       var _c = metaSlot($$);
                                                       var _rs = 1;
                                                       if (_c.operator === ':=' && _c.operands[1]
                                                               && (_c.operands[1][0] === '&' || _c.operands[1][0] === '^')) {
                                                           var _e = $$parser.symbols.functions[_c.operands[1].substr(1)];
                                                           if (_e && _e.signature && _e.signature.returnWords !== undefined
                                                                   && _e.signature.returnWords > 1)
                                                               _rs = _e.signature.returnWords;   /* multi-scalar OR by-value struct return window */
                                                       } else if (_c.type === 'F' && $$parser.isFuncTypeAtom(_c.elem)) {
                                                           var _ft = $$parser.functypes[_c.elem];   /* indirect call through a named funcptr type */
                                                           if (_ft.returnWords > 1) _rs = _ft.returnWords;
