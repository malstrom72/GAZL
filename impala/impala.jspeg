# ------------------------------------------------------------------
#  Simple variable & array declarators                          
# ------------------------------------------------------------------
# A leading type atom: a primitive keyword, or the name of a defined struct.
TypeBase    <-  t:BASE_TYPE _                                         { $$ = $$parser.CASTS_TO_TYPES[$t]; }
              / id:Identifier                                        {
                                                                         if (!$$parser.isStructAtom($id) && !$$parser.isFuncTypeAtom($id))
                                                                             $$parser.fail('Unknown type ' + $id, $$s, $$i, 'E413');
                                                                         $$ = $id;
                                                                     }

VarDecl     <-  base:TypeBase                                        { $desc = $base; }
                ( POINTER _                                           { $desc = 'p:' + $desc; }
                / ARRAY _ '[' _ x:Expr                                {   /* shape modifier `array[dims]`: prepends an array atom, e.g. int array[5] pointer -> p:[5]:i */
                                                                         var _d = $$parser.makeConstant($x, 'i', $$s, $$i);
                                                                         $vdims = [ $$parser.dropHash(_d) ];
                                                                         $$parser.returnBack(_d);
                                                                     }
                  ( ','_ x:Expr                                       {
                                                                         var _dn = $$parser.makeConstant($x, 'i', $$s, $$i);
                                                                         $vdims.push($$parser.dropHash(_dn));
                                                                         $$parser.returnBack(_dn);
                                                                     }
                  )* ']' _                                            { $desc = '[' + $vdims.join('x') + ']:' + $desc; }
                )*
                id:Identifier                                         {
                                                                         var head = $$parser.descHead($desc);
                                                                         var tail = $$parser.descTail($desc);
                                                                         if (tail === undefined && $$parser.isStructAtom(head)) {
                                                                             $$.type = 'S';
                                                                             $$.struct = head;
                                                                             $$.elem = undefined;
                                                                             $$.words = $$parser.structWords(head);
                                                                         } else if (tail === undefined && $$parser.isFuncTypeAtom(head)) {
                                                                             $$.type = 'F';           /* named funcptr type -> a funcptr carrying its type tag */
                                                                             $$.elem = head;
                                                                             $$.struct = undefined;
                                                                             $$.words = undefined;    /* scalar funcptr: a single word, no size operand */
                                                                         } else if ($$parser.isArrayAtom(head)) {
                                                                             $$parser.fail('a shape array type must be a pointer here (write `... pointer`); use `type array name[dims]` for a value array',
                                                                                     $$s, $$i, 'E414');
                                                                             $$.type = 'p'; $$.elem = tail; $$.struct = undefined; $$.words = undefined;   /* recover */
                                                                         } else {
                                                                             $$.type = head;
                                                                             $$.elem = tail;
                                                                             $$.struct = undefined;
                                                                             $$.words = undefined;
                                                                         }
