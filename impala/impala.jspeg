                                                               && meta.operands[1] === '&NULL'
                                                               && meta.operands[2] === undefined);
                                                       }
                                                       var winSlot = $$.base + $$.retSlots + $$.words;
                                                       if (meta.type === 'S') {              /* by-value struct argument spans sizeof words */
                                                           var w = $$parser.structWords(meta.struct);
                                                           $$parser.copyStructArg($a, winSlot, w);
                                                           $$.words += w;
                                                       } else {
                                                           $$parser.makeArgValue($a, winSlot);
                                                           $$.words += 1;
                                                       }
                                                    } }

Group       <-  '('_ Expr ')'_                      { if (!$$parser.dry)
                                                        $$parser.stampBitwise($$, false); }


BoolGroup   <-  '('_                                { $label = undefined; }
                And ('||'_                          { 
                                                        if ($label === undefined) { 
                                                            $label = $$parser.newLabel('t'); 
                                                        }
                                                        $$parser.emit('?->', true, $label, undefined, undefined); 
                                                    }
                And)* ')'_                          { 
                                                        if ($label !== undefined) { 
                                                            $$parser.emit('<-?', true, $label, undefined, undefined); 
                                                        } 
                                                    }


And         <-                                      { $label = undefined; }
                Comp ('&&'_                         { 
                                                        if ($label === undefined) { 
                                                            $label = $$parser.newLabel('f'); 
                                                        }
                                                        $$parser.emit('?->', false, $label, undefined, undefined); 
                                                    }
                Comp)*                              { 
                                                        if ($label !== undefined) { 
                                                            $$parser.emit('<-?', false, $label, undefined, undefined); 
                                                        } 
                                                    }


Comp        <-  '!'_ Comp                           { 
                                                        $$parser.emit('!', undefined, undefined, undefined, undefined); 
                                                    }
                /                                   { $$parser.dry = true; }
                    !Group                          { $$parser.dry = false; }
                    BoolGroup
                /                                   { $$parser.dry = false; }
                    Expr op:COMP_OP _ r:Expr        {
                                                        $$parser.checkCompMix($$, $r, $$s, $$i);
                                                        $$parser.binaryOp($op, $$, $r, $$s, $$i);
                                                        $$parser.emitMeta($$);
                                                        $$parser.releaseMeta($$);
                                                    }


Assert      <-  ASSERT _                            {
                                                        $okLabel = $$parser.newLabel('a');
                                                        $$parser.emit('<> ==', 'i', '#DEBUG', '#0', $okLabel);
                                                        $start    = $$i;
                                                        $exprText = '';
                                                    }
                str:BoolGroup                       {
                                                        $exprText = $$s.substring($start, $$i);
                                                        $exprText = $exprText.replace(/[ \t\r\n]+$/, '');
                                                    }
                ';'_                                {
                                                        $$parser.emit('?->', true, $okLabel, undefined, undefined);

                                                        var r = $$parser.borrowForCall();

                                                        /* store the assert-string constant */
                                                        $$parser.makeString('a', $str, $exprText, $$s, $$i);

                                                        /* argument goes into %<r+1> */
                                                        $$parser.makeArgValue($str, r + 1);

                                                        /* call the failure handler */
                                                        $$parser.emit('()', '?', '^assertFail',
                                                                      '%' + r, '*1');

                                                        /* tidy temporaries */
                                                        $$parser.returnBack('%' + (r + 1));
                                                        $$parser.returnBack('%' +  r);

                                                        /* continue after OK-label */
                                                        $$parser.emit('<-?', true, $okLabel, undefined, undefined);
                                                    }


Block       <-  '{'_ Statement* '}'_


Goto        <-  GOTO _ label:Identifier ';'_        {
                                                        $$parser.emit('-->', undefined, '@' + $label._, undefined, undefined);
                                                    }


# TODO : if full jump-optimisation is implemented we could always
#        fold the “empty else” block here.
If          <-  IF _ BoolGroup                      { 
                                                        $dontLabel = $$parser.newLabel('f');
                                                        $$parser.emit('?->', false, $dontLabel, undefined, undefined); 
                                                    }
                Statement (ELSE _                   { 
                                                        $doneLabel = $$parser.newLabel('e');
                                                        $$parser.emit('-->', undefined, $doneLabel, undefined, undefined);
                                                        $$parser.emit('<-?',  false, $dontLabel, undefined, undefined); 
                                                    }
                Statement                           { 
                                                        $$parser.emit('<--', undefined, $doneLabel, undefined, undefined); 
                                                    }
                /                                   { 
                                                        $$parser.emit('<-?', false, $dontLabel, undefined, undefined); 
                                                    }
                )


DoWhile     <-  DO _                                { 
                                                        $loopLabel = $$parser.newLabel('l');
                                                        $$parser.emit('<-?', false, $loopLabel, undefined, undefined); 
                                                    }
                Statement
                WHILE _ BoolGroup                   { 
                                                        $$parser.emit('?->', true, $loopLabel, undefined, undefined); 
                                                    }


Loop        <-  LOOP _                              { 
                                                        $loopLabel = $$parser.newLabel('l');
                                                        $$parser.emit('<--', undefined, $loopLabel, undefined, undefined); 
                                                    }
                Statement                           { 
                                                        $$parser.emit('-->', undefined, $loopLabel, undefined, undefined); 
                                                    }

# ---------------------------------------------------------------------------
#   FOR ... TO ... loop
# ---------------------------------------------------------------------------
For         <-  FOR _ '('_ var:Variable             {
                                                        /* loop-variable must be local, modifiable int / pointer */
                                                        var varMeta = metaSlot($var);
                                                        if (varMeta.operator !== '=' || span(varMeta.type, "ip") === 0) {
                                                            $$parser.fail(
                                                                'For variable must be a local modifiable int or pointer variable',
                                                                $$s, $$i
                                                            , 'E305');
                                                        }
                                                        $gotInit = false;            /* flag to detect an explicit start value */
                                                    }
                ('='_ init:Expr                     {
                                                        $$parser.assign($init, $var, $init, $$s, $$i);
                                                        $gotInit = true;
                                                    }
                )? TO _ toExpr:Expr ')'_            {
                                                        var varMeta  = metaSlot($var);
                                                        var toMeta   = metaSlot($toExpr);

                                                        if (toMeta.type !== varMeta.type) {
                                                            $$parser.typeError(
                                                                'Incompatible types ({$type1} and {$type2})',
                                                                $$s, $$i, varMeta.type, toMeta.type
                                                            , 'E301');
                                                        }

                                                        /* constant upper bound */
                                                        $to = $$parser.makeRValue(toMeta);

                                                        /* initial comparison  (var < to)                         */
                                                        $$parser.emit(
                                                            '<',
                                                            toMeta.type,
                                                            undefined,
                                                            $gotInit ? metaSlot($init).operands[1]     /* start value from “var = expr” */
                                                                     : varMeta.operands[1],            /* or the original variable */
                                                            $to
                                                        );

                                                        if ($gotInit) {
                                                            $$parser.releaseMeta($init);
                                                        }

                                                        /* branch-out   and  loop label */
                                                        $noLoopLabel = $$parser.newLabel('e');
                                                        $$parser.emit('?->', false, $noLoopLabel, undefined, undefined);

                                                        $loopLabel   = $$parser.newLabel('l');
                                                        $$parser.emit('<--', undefined, $loopLabel, undefined, undefined);
                                                    }
                body:Statement                      {
                                                        var varMeta = metaSlot($var);

                                                        /* increment + jump back */
                                                        $$parser.emit(
                                                            '...',
                                                            varMeta.type,
                                                            varMeta.operands[1],        /* address of loop variable */
                                                            $to,
                                                            $loopLabel
                                                        );
                                                        $$parser.emit('<-?', false, $noLoopLabel, undefined, undefined);

                                                        $$parser.returnBack($to);
                                                        $$parser.releaseMeta(varMeta);
                                                    }

# ---------------------------------------------------------------------------
#   COPY (len) FROM src TO dst
# ---------------------------------------------------------------------------
Copy        <-  COPY _ '('_ l:Expr FROM _ f:Expr TO _ t:Expr ')' _
                                                    {
                                                        var fromMeta = metaSlot($f);
                                                        var toMeta   = metaSlot($t);

                                                        $length = $$parser.makeConstant($l, 'i', $$s, $$i);
                                                        var lengthHash = $$parser.dropHash($length);

                                                        if (fromMeta.type + toMeta.type !== 'pp') {
                                                            $$parser.returnBack($length);
                                                            $$parser.typeError(
                                                                'Invalid types ({$type1} and {$type2})',
                                                                $$s, $$i, fromMeta.type, toMeta.type
                                                            , 'E301');
                                                        }

                                                        var copyMeta = metaSlot($l);
                                                        $$parser.makeMeta(
                                                            copyMeta,
                                                            'copy',
                                                            '?',
                                                            $$parser.makeRValue(toMeta, '&$%'),
                                                            $$parser.makeRValue(fromMeta, '&$%'),
                                                            '*' + lengthHash
                                                        );

                                                        $$parser.emitMeta(copyMeta);
                                                        $$parser.returnBack($length);
                                                        $$parser.releaseMeta(copyMeta);
                                                    }

# ---------------------------------------------------------------------------
#   Destructuring assignment for multi-value calls:  a, b = f(...)
#   (needs >= 2 targets before '='; single `a = ...` falls through to Expr)
# ---------------------------------------------------------------------------
Destructure <-                                      { if (!$$parser.dry) $$parser.destTargets = []; }
                DestTarget (','_ DestTarget)+ '='_  { $$parser.destructuring = true; }
                call:Expr ';'_                      { $$parser.destructuring = false;
                                                      if (!$$parser.dry)
                                                          $$parser.finishDestructure($call, $$parser.destTargets, $$s, $$i); }

DestTarget  <-                                      { $tgtGlobal = false; }
                (GLOBAL _                           { $tgtGlobal = true; }
                )?
                id:Identifier                       { if (!$$parser.dry)
                                                        $$parser.destTargets.push({ name: $id, isGlobal: $tgtGlobal,
                                                                                    code: $$s, offset: $$i }); }

# ---------------------------------------------------------------------------
#   SWITCH (expr == from TO to) { ... }
# ---------------------------------------------------------------------------
Switch      <-  SWITCH _ '('_ $$:Expr
                '=='_ f:Expr TO _ t:Expr    {
                                                        var switchMeta = metaSlot($$);

                                                        /* the switch expression must be an int */
                                                        if (switchMeta.type !== 'i') {
                                                            $$parser.fail('Switch expression needs to be int', $$s, $$i, 'E306');
                                                        }

                                                        /* lower bound (compile-time constant) */
                                                        switchMeta.from = $$parser.makeConstant($f, 'i', $$s, $$i);

                                                        /*    size = to - from   */
                                                        $size = $$parser.subConstInt(
                                                                     $$parser.makeConstant($t, 'i', $$s, $$i),
                                                                     switchMeta.from
                                                                 );

                                                        /*   switcher = (expr − from)   */
                                                        $switcher = $$parser.subConstInt(
                                                                         $$parser.makeRValue(switchMeta, '$%'),
                                                                         switchMeta.from
                                                                     );

                                                        switchMeta.switchLabel = $$parser.newLabel('s');
                                                        $switchExit              = $$parser.newLabel('e');

                                                        $$parser.switchStack.push(switchMeta);

                                                        $$parser.emit(
                                                            '-->#',
                                                            switchMeta.type,
                                                            $switcher,
                                                            '*' + $$parser.dropHash($size),
                                                            switchMeta.switchLabel
                                                        );

                                                        $$parser.returnBack($switcher);
                                                        $$parser.returnBack($size);

                                                        $progress = undefined;       /* track case / default presence */
                                                    }
                ')'_ '{'_
                (
                    ( CASE _                        {
                                                            /* multiple CASE groups -> fall-through handled here */
                                                            if ($progress !== undefined) {
                                                                $$parser.emit('-->', undefined, $switchExit, undefined, undefined);
                                                            } else {
                                                                $progress = 'gotCases';
                                                            }

                                                            /* dump the literal “case ...” comment */
                                                            var snippet = $$s.substr($$i);
                                                            var pos     = find(snippet, ":\r\n");
                                                            if (pos >= 0) {
                                                                snippet = snippet.substr(0, pos);
                                                            }
                                                            $$parser.emit(
                                                                ';', undefined,
                                                                'case ' + snippet,
                                                                undefined, undefined
                                                            );
                                                        }
                      CaseExpr
                      (','_ CaseExpr)*
                    / DEFAULT _                     {
                                                            if ($progress === 'gotDefault') {
                                                                $$parser.fail('Default case already defined', undefined, undefined, 'E409');
                                                            } else if ($progress !== undefined) {
                                                                $$parser.emit('-->', undefined, $switchExit, undefined, undefined);
                                                            }

                                                            var ctx = $$parser.switchStack[$$parser.switchStack.length - 1];

                                                            $$parser.emit(';',    undefined, 'default',       undefined, undefined);
                                                            $$parser.emit('<--',  undefined, ctx.switchLabel,  undefined, undefined);
                                                            $progress = 'gotDefault';
                                                        }
                    ) ':'_ stmt:Statement
                )*
                '}'_                                {
                                                        var ctx = $$parser.switchStack.pop() || metaSlot($$);

                                                        /* no explicit “default” -> hook it up now                        */
                                                        if ($progress !== 'gotDefault') {
                                                            $$parser.emit('<--', undefined, ctx.switchLabel, undefined, undefined);
                                                        }
                                                        $$parser.emit('<--', undefined, $switchExit, undefined, undefined);

                                                        $$parser.returnBack(ctx.from);
                                                    }

# ---------------------------------------------------------------------------
#   single “case ...” inside a switch
# ---------------------------------------------------------------------------
CaseExpr    <-  Expr                                {
                                                        /* offset = constant(expr) - switch.from                         */
                                                        var ctx      = $$parser.switchStack[$$parser.switchStack.length - 1];
                                                        var caseMeta = metaSlot($$);
                                                        var baseFrom = (ctx ? ctx.from : caseMeta.from);
                                                        var baseLabel = (ctx ? ctx.switchLabel : caseMeta.switchLabel);

                                                        $n = $$parser.subConstInt(
                                                                $$parser.makeConstant(caseMeta, 'i', $$s, $$i),
                                                                baseFrom
                                                            );

                                                        /* create label for this case                                     */
                                                        $$parser.emit(
                                                            '<--',
                                                            undefined,
                                                            baseLabel + '#' + $$parser.dropHash($n),
                                                            undefined, undefined
                                                        );

                                                        $$parser.returnBack($n);
                                                    }

# ---------------------------------------------------------------------------
#   WHILE  condition  statement
# ---------------------------------------------------------------------------
While       <-  WHILE _                             {
                                                        $loopLabel = $$parser.newLabel('l');
                                                        $$parser.emit('<--', undefined, $loopLabel, undefined, undefined);
                                                    }
                BoolGroup                           {
                                                        $exitLabel = $$parser.newLabel('e');
                                                        $$parser.emit('?->', false, $exitLabel, undefined, undefined);
                                                    }
                Statement                           {
                                                        $$parser.emit('-->', undefined, $loopLabel, undefined, undefined);
                                                        $$parser.emit('<-?', false, $exitLabel, undefined, undefined);
                                                    }

# ---------------------------------------------------------------------------
#   atomic values
# ---------------------------------------------------------------------------
Value       <-  Group
                / SIZEOF _ '('_ base:TypeBase        { if (!$$parser.dry) {
                                                        var head = $$parser.descHead($base);
                                                        var words = ($$parser.isStructAtom(head)
                                                                ? $$parser.structWords(head) : 1);
                                                        if (words === undefined)
                                                            $$parser.fail('sizeof of incomplete struct ' + head,
                                                                    $$s, $$i, 'E419');
                                                        $$parser.makeMeta($$, ':=', 'i', undefined, '#' + words, undefined);
                                                        $$parser.setElem($$, undefined);
                                                      } } ')'_
                / f:FloatLiteral                    { if (!$$parser.dry) {
                                                        $$parser.makeMeta($$, ':=', 'f', undefined, '#' + $f, undefined);
                                                        $$parser.setElem($$, undefined);
                                                      } }
                / i:IntegerLiteral                  { if (!$$parser.dry) {
                                                        $$parser.makeMeta($$, ':=', 'i', undefined, '#' + $i, undefined);
                                                        $$parser.setElem($$, undefined);
                                                      } }
                / s:StringLiteral                   { if (!$$parser.dry) {
                                                        $$parser.makeString('s', $$, evaluate($s), $$s, $$i);
                                                        $$parser.setElem($$, 'i');      /* string data is int words (Impala 2) */
                                                      } }
                / NULL _                            { if (!$$parser.dry) {
                                                        $$parser.makeMeta($$, ':=', 'p', undefined, '&NULL', undefined);
                                                        $$parser.setElem($$, undefined);
                                                      } }
                / NULLFUNC _                        { if (!$$parser.dry) {
                                                        $$parser.makeMeta($$, ':=', 'F', undefined, '&NULL', undefined);
                                                        $$parser.setElem($$, undefined);
                                                      } }
                / Variable

# ---------------------------------------------------------------------------
#   identifiers, optionally prefixed with “global”
# ---------------------------------------------------------------------------
Variable    <-                                      { $global = false; }
                (GLOBAL _                           { $global = true; }
                )?
                id:Identifier                       { if (!$$parser.dry) {
                                                        $$parser.lookup($$, $id, $global, $$s, $$i);
                                                      } }


########################
#    Lexical Syntax    #
########################

Identifier      <-  !KEYWORD $$=([A-Za-z_$] SYMBOL_CHAR*) _
FloatLiteral    <-  $$=([-+]? DIGIT+ "." DIGIT+ (("E" / "e") ([-+]? DIGIT+))?) _
IntegerLiteral  <-  $$=([-+]? ("0x" HEX+ / "'" (!"'" ASCII)* "'" / DIGIT+)) _
StringLiteral   <-  $$=( '"' ( !["\\\0-\37] . / "\\" ( [\"\\bfnrt] / 'u' HEX HEX HEX HEX ) )* '"' ) _

KEYWORD     <-  ABS / ARRAY / ASSERT / CASE / CONST / COPY / DEFAULT / DO / ELSE / EXPORT / EXTERN / FLOAT / FLOOR / FOR / FROM
                / FTOI / FUNCPTR / FUNCTYPE / FUNCTION / GLOBAL / GOTO / IF / IMPORT / INT / ITOF / LOCALS / LOOP / NATIVE / NULL / NULLFUNC
                / POINTER / READONLY / RETURNS / SIZEOF / STRUCT / SWITCH / TEMPORARY / TO / WHILE

ABS         <-  'abs' !SYMBOL_CHAR          ARRAY       <-  'array' !SYMBOL_CHAR
ASSERT      <-  'assert' !SYMBOL_CHAR       CASE        <-  'case' !SYMBOL_CHAR
CONST       <-  'const' !SYMBOL_CHAR        COPY        <-  'copy' !SYMBOL_CHAR
DEFAULT     <-  'default' !SYMBOL_CHAR
DO          <-  'do' !SYMBOL_CHAR           ELSE        <-  'else' !SYMBOL_CHAR
EXPORT      <-  'export' !SYMBOL_CHAR       IMPORT      <-  'import' !SYMBOL_CHAR
EXTERN      <-  'extern' !SYMBOL_CHAR       FLOAT       <-  'float' !SYMBOL_CHAR
FLOOR       <-  'floor' !SYMBOL_CHAR        FOR         <-  'for' !SYMBOL_CHAR
FROM        <-  'from' !SYMBOL_CHAR
FTOI        <-  'ftoi' !SYMBOL_CHAR         FUNCPTR     <-  'funcptr' !SYMBOL_CHAR
FUNCTYPE    <-  'functype' !SYMBOL_CHAR
FUNCTION    <-  'function' !SYMBOL_CHAR     GLOBAL      <-  'global' !SYMBOL_CHAR
GOTO        <-  'goto' !SYMBOL_CHAR         IF          <-  'if' !SYMBOL_CHAR
INT         <-  'int' !SYMBOL_CHAR          ITOF        <-  'itof' !SYMBOL_CHAR
LOCALS      <-  'locals' !SYMBOL_CHAR       LOOP        <-  'loop' !SYMBOL_CHAR
NATIVE      <-  'native' !SYMBOL_CHAR       NULL        <-  'null' !SYMBOL_CHAR
NULLFUNC    <-  'nullfunc' !SYMBOL_CHAR
POINTER     <-  'pointer' !SYMBOL_CHAR      READONLY    <-  'readonly' !SYMBOL_CHAR
RETURNS     <-  'returns' !SYMBOL_CHAR      SWITCH      <-  'switch' !SYMBOL_CHAR
SIZEOF      <-  'sizeof' !SYMBOL_CHAR       STRUCT      <-  'struct' !SYMBOL_CHAR
TEMPORARY   <-  'temporary' !SYMBOL_CHAR    TO          <-  'to' !SYMBOL_CHAR
WHILE       <-  'while' !SYMBOL_CHAR

BITWISE_OP  <-  $$=( '<<' / '>>>' / '>>' / '|' !'|' / '&' !'&' / '^' )
ADDSUB_OP   <-  $$=( '+' / '-' )
MULDIV_OP   <-  $$=( '*' / '/' !'/' / '%' )
COMP_OP     <-  $$=( '<=' / '>=' / '!=' / '==' / '<' / '>' )
BASE_TYPE   <-  INT                               { $._ = 'int'; }
            /  FLOAT                              { $._ = 'float'; }
            /  FUNCPTR                            { $._ = 'funcptr'; }
            /  POINTER                            { $._ = 'pointer'; }
BUILT_IN    <-  $$=( 'abs' / 'floor' / 'itof' / 'ftoi' )
PREFIX_OP   <-  $$=( '-' !("'" / DIGIT)
                   / '~'
                   / '&'
                   / '*'
                   / BUILT_IN !SYMBOL_CHAR
                 )
SYMBOL_CHAR <-  [A-Za-z_$0-9]
HEX         <-  [0-9A-Fa-f]
DIGIT       <-  [0-9]
ASCII       <-  ![\0-\37] .
_           <-  ([ \t\r\n]+ / COMMENT)*
COMMENT     <-  '/*' (!'*/' .)* '*/' / "//" (![\r\n] .)*
