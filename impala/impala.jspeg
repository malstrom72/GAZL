                / Value (FuncCall / Subscript / FieldAccess)*

Subscript   <-  '['_                               { if (!$$parser.dry) {
                                                       var _sb = metaSlot($$);
                                                       $subMulti = (_sb.dims !== undefined && _sb.dims.length >= 2)
                                                               || (_sb.type === 'p' && _sb.elem !== undefined
                                                                       && $$parser.isArrayAtom($$parser.descHead(_sb.elem)));
                                                       $subRV = []; $subCols = 0; $subColSeen = false; $subNode = undefined;
                                                     } }
                ( ':' _                            { if (!$$parser.dry) {
                                                       if (!$subMulti) { $subMulti = true; if ($subNode !== undefined && $subRV.length === 0) $subRV.push($$parser.makeRValue(metaSlot($subNode))); }
                                                       $subCols++; $subColSeen = true;
                                                     } }
                / s:Expr                           { if (!$$parser.dry) {
                                                       if ($subColSeen) $$parser.fail("an open axis ':' must be trailing (a column/strided slice is not a contiguous array)", $$s, $$i, 'E421');
                                                       if ($subNode === undefined) $subNode = $s;
                                                       if ($subMulti) $subRV.push($$parser.makeRValue(metaSlot($s)));
                                                     } }
                )
                ( ','_
                  ( ':' _                          { if (!$$parser.dry) {
                                                       if (!$subMulti) { $subMulti = true; if ($subNode !== undefined && $subRV.length === 0) $subRV.push($$parser.makeRValue(metaSlot($subNode))); }
                                                       $subCols++; $subColSeen = true;
                                                     } }
                  / s:Expr                         { if (!$$parser.dry) {
                                                       if ($subColSeen) $$parser.fail("an open axis ':' must be trailing (a column/strided slice is not a contiguous array)", $$s, $$i, 'E421');
                                                       if (!$subMulti) { $subMulti = true; if ($subNode !== undefined && $subRV.length === 0) $subRV.push($$parser.makeRValue(metaSlot($subNode))); }
                                                       $subRV.push($$parser.makeRValue(metaSlot($s)));
                                                     } }
                  )
                )* ']'_                            { if (!$$parser.dry) {
                                                       if ($subCols > 0) {
                                                           $$parser.arraySlice($$, $subRV, $subCols, $$s, $$i);
                                                       } else if ($subMulti) {
                                                           $$parser.arraySubscriptFlat($$, $subRV, $$s, $$i);
                                                       } else {
                                                           var sb = metaSlot($$);
                                                           if (sb.type === 'p' && $$parser.isStructAtom(sb.elem))
