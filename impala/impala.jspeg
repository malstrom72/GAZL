    function random() {
        return Math.random();
    }
    function floor(x) {
        return Math.floor(x);
    }
    function time() {
        return (new Date()).getTime();
    }


    /* --------------------------------
     *  Impala-JSPEG  ▸  core tables / helpers  (ES3)
