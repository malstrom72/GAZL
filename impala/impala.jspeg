                $$parser.fail('Whole-struct assignment needs a struct value on both sides',
                        sourceCode, sourceOffset, 'E420');
            }
            if (leftx.struct !== rightx.struct) {
                $$parser.fail('Struct type mismatch in assignment (' + leftx.struct + ' = '
                        + rightx.struct + ')', sourceCode, sourceOffset, 'E420');
            }
            var words   = $$parser.structWords(leftx.struct);
            var savedBK = leftx.baseKind, savedBase = leftx.base,
                savedOff = leftx.placeOff, savedStruct = leftx.struct;
            var dst = $$parser.placeAddress(leftx);
            var src = $$parser.placeAddress(rightx);
            $$parser.makeMeta(x, 'copy', '?', dst, src, '*' + words);
            $$parser.emitMeta(x);
            $$parser.returnBack(src);
            $$parser.returnBack(dst);
            $$parser.freeStructWindow(rightx);                    /* release a struct-return window once copied out */
            $$parser.setPlace(x, savedBK, savedBase, savedOff, savedStruct);
            return;
        }

        if (!leftx || leftx.operator === undefined) {
            throw new Error('JSPEG meta missing for assignment: ' + JSON.stringify(leftx));
        }

        var lop   = leftx.operator;
        var keep  = 2;          /* operand index to keep for r-value */

        if (leftx.type !== '?' && rightx.type === '?' && rightx.callInfo && rightx.callInfo.name) {
            $$parser.expectFunctionReturnType(rightx.callInfo.name, leftx.type, sourceCode, sourceOffset);
            rightx.type = leftx.type;
            $$parser.updateCallExpectationComment(rightx.callInfo, leftx.type);
        }

        if (leftx.type !== '?' && rightx.type !== '?' && leftx.type !== rightx.type) {
            $$parser.typeError(
                'Incompatible types for assignment ({$type1} = {$type2})',
                sourceCode, sourceOffset,
                leftx.type, rightx.type
            , 'E303');
        }

        $$parser.checkPtrAssign(leftx, rightx, sourceCode, sourceOffset);

        /* fast path: constant expression on RHS */
        var op1 = rightx.operands[1];
        var op2 = rightx.operands[2];
        var constPair  = (op1 ? op1[0] : '') +
                         (op2 ? op2[0] : '');
        var rhsConst   = (span(constPair, '#<') === constPair.length);

        if (lop === '=' && rhsConst) {

            $$parser.makeMeta(
                x, ':=', rightx.type,
                leftx.operands[1],
                $$parser.makeRValue(rightx),
                null
            );
            keep = 1;

        } else if (lop === '=') {

            $$parser.makeMeta(
                x, rightx.operator, rightx.type,
                leftx.operands[1],
                rightx.operands[1],
                rightx.operands[2]
            );
            keep = ((x.operator === '=' || x.operator === ':=') ? 1 : 0);

        } else if (lop === '=*') {

            $$parser.makeMeta(
                x, '*=', rightx.type,
                leftx.operands[1],
                $$parser.makeRValue(rightx),
                null
            );
            keep = 1;

        } else if (lop === '=[]') {

            $$parser.makeMeta(
                x, '[]=', rightx.type,
                leftx.operands[1],
                leftx.operands[2],
                $$parser.makeRValue(rightx)
            );

        } else if (lop === '=[]$') {

            $$parser.makeMeta(
                x, '[]$=', rightx.type,
                leftx.operands[1],
                leftx.operands[2],
                $$parser.makeRValue(rightx)
            );

        } else {
            $$parser.fail("Invalid lvalue", sourceCode, sourceOffset, 'E404');
        }

        /* push the instruction just built */
        $$parser.emitMeta(x);

        /* release all temporaries except the one we keep */
        for (var i = 2; i >= 0; --i) {
            if (i !== keep) {
                $$parser.returnBack(x.operands[i]);
            }
        }

        /* finally generate r-value of assignment */
        $$parser.makeMeta(
            x, '=', x.type,
            null,
            x.operands[keep],
            null
        );
    };

    /* -----------------------------------------------------------
     *  Multi-return destructuring   a, b = f(...)
     *  callMeta is the finished FuncCall meta whose output window
     *  lives in %multiBase .. %multiBase+multiCount-1.
     * -------------------------------------------------------- */
    $$parser.finishDestructure = function (callMeta, targets, sourceCode, sourceOffset) {
        callMeta = metaSlot(callMeta);
        var base  = callMeta.multiBase;
        var count = callMeta.multiCount;
        var list  = callMeta.multiReturnList || [];

        if (base === undefined || count === undefined || count < 2) {
            $$parser.fail('Left side lists ' + targets.length
                    + ' targets but the right side is not a multi-value function call',
                    sourceCode, sourceOffset, 'E432');
        }
        if (targets.length !== count) {
            $$parser.fail('Destructuring assignment expects ' + count
                    + ' targets, got ' + targets.length,
                    sourceCode, sourceOffset, 'E433');
        }

        for (var i = 0; i < count; ++i) {
            var slot = '%' + (base + i);
            var t    = targets[i];
            var ret  = list[i] || {};

            if (t.name === '_') {                     /* discard: slot freed in the release pass below */
                continue;
            }

            var lv = { operator: undefined, type: '?',
                       operands: [ undefined, undefined, undefined ] };
            $$parser.lookup(lv, t.name, t.isGlobal, t.code, t.offset);

            var rv = { operator: ':=', type: (ret.type || '?'),
                       operands: [ undefined, slot, undefined ] };
            $$parser.setElem(rv, ret.elem);

            var res = { operator: undefined, type: '?',
                        operands: [ undefined, undefined, undefined ] };
            $$parser.assign(res, lv, rv, sourceCode, sourceOffset);  /* reads %slot; leaves it allocated */
        }

        /* Release the output-window slots high-to-low, the LIFO order every other multi-slot
           window (arg window, struct-return window) already uses. Freeing low-to-high left a
           hole below a live temp, breaking borrowForCall's reuse (invariant R2 / fuzzer 10024). */
        for (var j = count - 1; j >= 0; --j) {
            $$parser.returnBack('%' + (base + j));
        }
    };

    /* -----------------------------------------------------------
     *  Unary helpers  (dereference, reference, -, ~, abs/floor,
     *                  int↔float conversions)
     * -------------------------------------------------------- */

    /* *expr  or  [] dereference handling */
    $$parser.dereference = function (operator, expr, sourceCode, sourceOffset) {
        expr = metaSlot(expr);
        if (expr.operator === '+') {
            /*  &a + i   ->   PEEK (&a , i)  */
            expr.operator = '=[]';
        } else if (expr.operator === '-' && expr.operands[2] &&
                   expr.operands[2][0] === '#') {
            /*  &a - #n  where n is const -> adjust to negative literal */
            expr.operator = '=[]';
            var num = parseFloat(expr.operands[2].substr(1));   // strip leading '#'
            expr.operands[2] = '#'+(-num);
        } else {
            /* generic “*expr” */
            $$parser.makeMeta(
                expr, operator, '?',
                undefined,
                $$parser.makeRValue(expr),
                undefined
            );
        }
    };

    /* & (address-of) operator handling */
    $$parser.reference = function (operator, expr, sourceCode, sourceOffset) {

        expr = metaSlot(expr);

        if (expr.operator === '=') {                 // variable
            assert(expr.operands[2] === undefined,
                   "expr.operands[2] must be void for '=' lvalue");
            expr.operator  = '=&';
            expr.operands[2] = '*0';

        } else if (expr.operator === '=*' || expr.operator === ':=*') {
            assert(expr.operands[2] === undefined,
                   "expr.operands[2] must be void for '=*' lvalue");
            expr.operator = ':=';                    // treat as plain r-value

        } else if (expr.operator === '=[]') {        // array element
            expr.operator = '+';                     // &a[i]  ->  &a + i

        } else if (expr.operator === '=[]$') {       // local array element
            expr.operator = '=&';
            var index = expr.operands[2];            // save index before clobber
            expr.operands[2] = '*0';
            $$parser.makeMeta(
                expr, '+', 'p',
                undefined,
                $$parser.makeRValue(expr),           // &base
                index                                // + offset
            );

        } else {
            $$parser.fail("Invalid lvalue", sourceCode, sourceOffset, 'E404');
        }
    };

    /* unary minus (integer/float) */
    $$parser.minus = function (operator, expr/*, src, off*/) {
        expr = metaSlot(expr);
        $$parser.makeMeta(
            expr, '-', undefined,
            undefined,
            $$parser.ZEROES[ expr.type ],            // 0  of same type
            $$parser.makeRValue(expr)
        );
    };

    /* bit-wise NOT / logical NOT  (~expr) */
    $$parser.not = function (operator, expr) {
        expr = metaSlot(expr);
        $$parser.makeMeta(
            expr, '^', undefined,
            undefined,
            $$parser.makeRValue(expr),
            '#-1'                                    // XOR with -1
        );
    };

    /* ABS or FLOOR (unary) - operator is already '=abs' or '=floor' */
    $$parser.absFloor = function (operator, expr) {
        expr = metaSlot(expr);
        $$parser.makeMeta(
            expr, operator, undefined,
            undefined,
            $$parser.makeRValue(expr),
            undefined
        );
    };

    /* int -> float */
    $$parser.intToFloatConvert = function (operator, expr) {
        expr = metaSlot(expr);
        $$parser.makeMeta(
            expr, '=itof', undefined,
            undefined,
            $$parser.makeRValue(expr),
            '#1.0'
        );
    };

    /* float -> int, with constant-fold special-case */
    $$parser.floatToIntConvert = function (operator, expr) {

        expr = metaSlot(expr);

        var op1 = expr.operands[1],
            op2 = expr.operands[2];

        /* expr is  (const|<tmp>) * #1.0  pattern */
        if (expr.operator === '*' && op2 && span(op2[0], '#<') === 1) {
            $$parser.makeMeta(expr, '=ftoi', undefined, undefined, op1, op2);

        } else if (expr.operator === '*' && op1 && span(op1[0], '#<') === 1) {
            $$parser.makeMeta(expr, '=ftoi', undefined, undefined, op2, op1);

        } else {    // generic cast
            $$parser.makeMeta(
                expr, '=ftoi', undefined,
                undefined,
                $$parser.makeRValue(expr),
                '#1.0'
            );
        }
    };

    /* -----------------------------------------------------------
     *  UNARY_OPS dispatch table
     * -------------------------------------------------------- */

    $$parser.UNARY_OPS = {};          /* will hold “=xxx” -> handler */

    /* no-op casts */
    function noop() {}

    /* register the handlers */
    map($$parser.UNARY_OPS,
        '=float',     noop,
        '=funcptr',   noop,
        '=int',       noop,
        '=pointer',   noop,

        '=*',         $$parser.dereference,
        '=&',         $$parser.reference,
        '=-',         $$parser.minus,
        '=~',         $$parser.not,
        '=abs',       $$parser.absFloor,
        '=itof',      $$parser.intToFloatConvert,
        '=ftoi',      $$parser.floatToIntConvert,
        '=floor',     $$parser.absFloor
    );

    /* -----------------------------------------------------------
     *  Generic unary operator
     * -------------------------------------------------------- */
    $$parser.unaryOp = function (operator, expr, sourceCode, sourceOffset) {

        expr = metaSlot(expr);

        /* *structPointer -> a struct place (through-pointer field access / whole-struct assign) */
        if (operator === '*' && expr.type === 'p' && $$parser.isStructAtom(expr.elem)) {
            $$parser.setPlace(expr, 'pointer', $$parser.makeRValue(expr), 0, expr.elem);
            return;
        }

        /* &structValue -> a typed struct pointer (materialize the place's address) */
        if (operator === '&' && expr.place) {
            var structName = expr.struct;
            var addr = $$parser.placeAddress(expr);
            $$parser.makeMeta(expr, ':=', 'p', undefined, addr, undefined);
            $$parser.setElem(expr, structName);
            return;
        }

        /* &slice -> a shape-carrying pointer to the sub-array (its address is already computed) */
        if (operator === '&' && expr.slice) {
            var sliceAddr = expr.operands[1];
            var sliceElem = expr.elem;
            $$parser.makeMeta(expr, ':=', 'p', undefined, sliceAddr, undefined);
            $$parser.setElem(expr, sliceElem);
            return;
        }

        /* &wholeArray -> a shape-carrying pointer to the whole array (Impala 2 multidim). Handled here,
           before the generic element propagation below, which would otherwise overwrite the shape. */
        if (operator === '&' && expr.dims !== undefined) {
            var shapeDesc = $$parser.arrayDesc(expr.dims, expr.elem);
            var arrAddr   = $$parser.makeRValue(expr);   /* ADRL for a local, &name for a global */
            $$parser.makeMeta(expr, ':=', 'p', undefined, arrAddr, undefined);
            $$parser.setElem(expr, shapeDesc);
            metaSlot(expr).dims = undefined;             /* it is now a pointer value, not the array */
            return;
        }

        var key      = '=' + operator;                // e.g. "=abs"
        var prevType = expr.type;                     /* for element-type propagation (Impala 2) */
        var prevElem = expr.elem;

        /* check type support */
        var sig  = key + expr.type;                   // e.g. "=absf"
        var rTyp = $$parser.SUPPORTED_OPS[ sig ];
        if (rTyp == null) {
            $$parser.typeError('Invalid type ({$type1})',
                               sourceCode, sourceOffset, expr.type, undefined, 'E302');
        }

        /* dispatch actual work */
        var fn = $$parser.UNARY_OPS[ key ];
        if (fn) {
            fn(key, expr, sourceCode, sourceOffset);
        }

        /* update resulting type */
        expr.type = rTyp;

        /* element-type propagation (Impala 2) */
        if (key === '=*') {
            if (prevElem !== undefined) {
                expr.type = $$parser.descHead(prevElem);          /* typed dereference: no cast needed */
                expr.elem = $$parser.descTail(prevElem);
            } else {
                expr.elem = undefined;
            }
        } else if (key === '=&') {
            if (prevType === 'F' && $$parser.isFuncTypeAtom(prevElem)) {
                expr.elem = prevElem;                             /* &funcptr -> element is the named funcptr type
                                                                     (its name already identifies it, like a struct) */
            } else {
                expr.elem = (prevType === undefined ? undefined   /* &x yields a pointer to x's type */
                        : prevType + (prevElem !== undefined ? ':' + prevElem : ''));
            }
        } else {
            expr.elem = undefined;                                /* casts and numeric ops erase */
        }
    };

    /* -----------------------------------------------------------
     *  Symbol declaration helper
     * -------------------------------------------------------- */

    function $$parser.declare(kind, scope, name, type, readonly, value, sourceCode, sourceOffset, comment, elem, dims) {
        /* emit data / flush pending code */
        if (kind !== undefined) {
            $$parser.flushMetaCode('');

            if (typeof output === 'function') {
                var line = '';
                if (scope === 'locals') line += (typeof TAB !== 'undefined' ? TAB : '\t');
                if (name != null)       line += name + ':';
                line += '\t' +
                        replace(kind, '?', $$parser.TYPE_SUFFIXES[type] || '');
                if (value !== undefined) line += ' ' + value;
                if (comment)             line += '\t; ' + comment;

                output( line );
            }
        }

        /* give any temporary back to the pool */
        $$parser.returnBack(value);

        /* register in symbol table */
        if (name !== undefined) {
            var table = $$parser.symbols[scope];
            var prev  = table && table[name];

            if (prev) {
                if (kind !== undefined && prev.kind !== undefined) {
                    $$parser.fail('Identifier already declared: ' + name,
                                  sourceCode, sourceOffset, 'E401');
                }
                if (type !== prev.type) {
                    $$parser.typeError('Type mismatch with previous declaration of ' +
                                       name + ' (was {$type1})',
                                       sourceCode, sourceOffset, prev.type, undefined, 'E402');
                }
                if (prev.elem !== undefined && elem !== undefined && prev.elem !== elem) {
                    $$parser.fail('Element type mismatch with previous declaration of ' + name
                                  + ' (was ' + $$parser.elemVerbose(prev.elem) + ', now '
                                  + $$parser.elemVerbose(elem) + ')',
                                  sourceCode, sourceOffset, 'E203');
                }
                /* inherit old flags */
                kind     = (kind     !== undefined ? kind     : prev.kind);
                readonly = (readonly || prev.readonly);
                elem     = (elem     !== undefined ? elem     : prev.elem);
                dims     = (dims     !== undefined ? dims     : prev.dims);
            }

            /* store / update */
            if (!table) $$parser.symbols[scope] = table = {};
            table[name] = {
                type: type,
                elem: elem,
                dims: dims,
                readonly: !!readonly,
                kind: kind,
                signature: prev && prev.signature,
                sourceCode: sourceCode,
                sourceOffset: sourceOffset,
                sourceName: ($$parser.sourceName !== undefined ? $$parser.sourceName
                                                               : (prev ? prev.sourceName : undefined))
            };
        }
    };

    /* -----------------------------------------------------------
     *  Flush all queued meta-code into final text output
     * -------------------------------------------------------- */
    $$parser.flushMetaCode = function (prefix) {

        prefix = prefix || '';
        var TABstr = (typeof TAB !== 'undefined') ? TAB : '\t';

        var nextLabel   = TABstr;   // pending label prefix
        var nextComment = '';       // pending trailing comment
        function formatOperand(op) {
            return (op == null ? '' : op);
        }

        for (var i = 0; i < $$parser.metacode.length; ++i) {

            var rec   = $$parser.metacode[i];
            var op    = rec.operator;

            if (op == null) {
                /* empty / removed meta - skip */
                continue;
            }

            /* -------------------------------------------------- */
            /* handle a stand-alone label (“<--”)                 */
            /* -------------------------------------------------- */
            if (op === '<--') {
                assert(rec.operands[0][0] === '@',
                       "label must start with '@'");
                if (nextLabel !== TABstr) {
                    output(prefix + nextLabel + 'NOOP');
                }
                nextLabel = rec.operands[0].substr(1) + ':' + TABstr;
                continue;
            }

            /* -------------------------------------------------- */
            /* comment pseudo-op (“; ...”)                          */
            /* -------------------------------------------------- */
            if (op === ';') {
                nextComment = '\t; ' +
                             replace(rec.operands[0], '\t', ' ');
                continue;
            }

            /* -------------------------------------------------- */
            /* compile-time op (string starts with '<> ')         */
            /* -------------------------------------------------- */
            if (op.substr(0, 3) === '<> ') {

                if (nextLabel !== TABstr) {
                    output(prefix + nextLabel + 'NOOP');
                }
                nextLabel = TABstr;

                var gop = $$parser.META_TO_GAZL[ op.substr(3) ];
                gop      = replace(gop, '?',
                                   $$parser.TYPE_SUFFIXES[ rec.type ]);

                output(prefix + '\t! ' + gop + ' ' +
                       formatOperand(rec.operands[0]) + ' '   +
                       formatOperand(rec.operands[1]) + ' '   +
                       formatOperand(rec.operands[2]) + nextComment);

                nextComment = '';
                continue;
            }

            /* -------------------------------------------------- */
            /* normal run-time instruction                        */
            /* -------------------------------------------------- */
            var gInstr = $$parser.META_TO_GAZL[ op ];
            gInstr     = replace(gInstr, '?',
                                 $$parser.TYPE_SUFFIXES[ rec.type ]);

            output(prefix + nextLabel + gInstr + ' ' +
                   formatOperand(rec.operands[0]) + ' ' +
                   formatOperand(rec.operands[1]) + ' ' +
                   formatOperand(rec.operands[2]) + nextComment);

            nextLabel   = TABstr;
            nextComment = '';
        }

        /* reset queue */
        $$parser.metacode.length = 0;
    };

    /* -----------------------------------------------------------
     *  Identifier lookup helper
     * -------------------------------------------------------- */
    $$parser.lookup = function (x, name, isGlobal, sourceCode, sourceOffset) {

        var sym = $$parser.symbols;
        var p   = null;

        /* local  ------------------------------------------------*/
        if (!isGlobal && (p = sym.locals['$' + name])) {

            if (p.type === 'S') {                                 /* struct value local -> a place */
                $$parser.setPlace(x, 'local', '$' + name, 0, p.elem);
                return;
            }
            if (p.type === 'A') {
                $$parser.makeMeta(x, '=&', 'p', undefined,
                                  '$' + name, '*0');
                metaSlot(x).dims = p.dims;                         /* carry the array shape for multi-dim subscript */
            } else {
                $$parser.makeMeta(x,
                                  (p.readonly ? ':=' : '='),
                                  p.type,
                                  undefined,
                                  '$' + name,
                                  undefined);
            }
            $$parser.setElem(x, p.elem);
            return;
        }

        /* global -----------------------------------------------*/
        if (isGlobal && (p = sym.globals[name])) {

            if (p.type === 'S') {                                 /* struct value global -> a place in global memory */
                $$parser.setPlace(x, 'globalAddr', '&' + name, 0, p.elem);
                return;
            }
            if (p.type === 'A') {
                $$parser.makeMeta(x, ':=', 'p', undefined,
                                  '&' + name, undefined);
                metaSlot(x).dims = p.dims;                         /* carry the array shape for multi-dim subscript */
            } else {
                $$parser.makeMeta(x,
                                  (p.readonly ? ':=*' : '=*'),
                                  p.type,
                                  undefined,
                                  '&' + name,
                                  undefined);
            }
            $$parser.setElem(x, p.elem);
            return;
        }

        /* function ---------------------------------------------*/
        if ((p = sym.functions[name])) {
            if (p.type === 'N') {
                $$parser.makeMeta(x, ':=', 'N', undefined,
                                  '^' + name, undefined);
            } else {
                assert(p.type === 'U', 'function entry must be U');
                $$parser.makeMeta(x, ':=', 'F', undefined,
                                  '&' + name, undefined);
            }
            $$parser.setElem(x, undefined);
            return;
        }

        /* constant / #define -----------------------------------*/
        if ((p = sym.defines[name])) {
            $$parser.makeMeta(x, ':=', p.type, undefined,
                              '#' + name, undefined);
            $$parser.setElem(x, p.elem);
            return;
        }

        /* not found --------------------------------------------*/
        $$parser.fail('Undeclared identifier: ' + name,
                      sourceCode, sourceOffset, 'E403');
    };

    /* -----------------------------------------------------------
     *  Ensure expression resolves to a compile-time constant
     * -------------------------------------------------------- */
    $$parser.makeConstant = function (x, wantType,
                                      sourceCode, sourceOffset) {

        var r = $$parser.makeRValue(x, '#<&');

        if (x.type !== wantType ||
            span(r[0], '#<&') !== 1) {

            $$parser.fail(
                bake('Expected constant ' +
                     $$parser.VERBOSE_TYPES[ wantType ]),
                sourceCode, sourceOffset, 'E407');
        }
        return r;
    };

    /* -----------------------------------------------------------
     *  Constant subtraction helper
     * -------------------------------------------------------- */
    $$parser.subConstInt = function (opL, opR) {

        assert(span(opR[0], '#<') === 1,
               "rhs must be const");

        /* trivial cases */
        if (opR === '#0') return opL;

        if (opL[0] === '#' && opR[0] === '#' &&
            span(opL.substr(1), '0123456789') === opL.length - 1 &&
            span(opR.substr(1), '0123456789') === opR.length - 1) {

            return '#' + ( parseInt(opL.substr(1), 10) -
                           parseInt(opR.substr(1), 10) );
        }

        /* need run-time temp */
        $$parser.returnBack(opL);

        var tmp;
        if (span(opL[0], '#<') === 1) {
            $$parser.emit('<> -', 'i',
                          tmp = $$parser.borrow('<'),
                          opL, opR);
        } else {
            $$parser.emit('-', 'i',
                          tmp = $$parser.borrow('%'),
                          opL, opR);
        }
        return tmp;
    };

    /* drop leading “#” helper */
    $$parser.dropHash = function (s) {
        return (s[0] === '#') ? s.substr(1) : s;
    };

    /* printable ASCII table (33-126) */
    $$parser.printable = '';
    for (var i = 33; i < 127; ++i) {
        $$parser.printable += char(i);
    }

    /* -----------------------------------------------------------
     *  Dump a string constant into assembly
     * -------------------------------------------------------- */
    $$parser.dumpString = function (label, str) {

        var len = str.length;
        $$parser.declare('CNST', 'globals', label, '?',
                         true, '*' + len, '', 0);

        var offset = 0;
        while (offset < len) {

            /* raw bytes before printable chunk */
            var non = find(str.substr(offset), $$parser.printable);
            if (non > 0) {
                var d = '';
                for (var k = 0; k < non; ++k) {
                    d += ' #' + ordinal(str[offset + k]);
                }
                $$parser.declare('DATi', undefined, undefined, 'i',
                                 true, d.substr(1), '', 0);
                offset += non;
                continue;
            }

            /* printable (plus spaces) */
            var spanLen = span(str.substr(offset),
                               $$parser.printable + ' ');
            spanLen = rspan(str.substr(offset, spanLen), ' ');
            if (spanLen > 0) {
                $$parser.declare('DATs', undefined, undefined, 'i',
                                 true, str.substr(offset, spanLen), '', 0);
                offset += spanLen;
            }
        }
    };

    /* -----------------------------------------------------------
     *  Manage / share string literals
     * -------------------------------------------------------- */
    $$parser.makeString = function (prefix, x, s,
                                    sourceCode, sourceOffset) {

        s += char(0);       // NUL-terminate

        var byteString = '';
        for (var idx = 0; idx < s.length; ++idx) {
            byteString += char(ordinal(s[idx]));
        }
        s = byteString;

        var tbl = $$parser.strings[prefix];
        if (!tbl) {
            tbl = $$parser.strings[prefix] = [];
            tbl.rlookup = {};
        }

        var entry = tbl.rlookup[s];
        if (entry == null) {

            /* generate unique label */
            var name = '.' + prefix + '_' +
                       (s.replace(/[^0-9a-zA-Z]/g, '')
                          .substr(0, 6)) +
                       '_' +
                       ( (($$parser.randomId + tbl.length) >>> 0)
                         .toString(16) );

            if ($$parser.noForward) {
                $$parser.dumpString(name, s);
            } else {
                tbl.push({ name:name, data:s });
            }

            /* add all suffixes to rlookup */
            for (var k = 0; k < s.length; ++k) {
                tbl.rlookup[ s.substr(k) ] =
                    name + (k ? ':' + k : '');
            }
            entry = name;            // full string label
        }

        $$parser.makeMeta(x, ':=', 'p',
                          undefined, '&' + entry, undefined);
    };

    /* -----------------------------------------------------------
     *  Tiny utilities still missing from the toolbox
     * -------------------------------------------------------- */

    /* wipe an Array or plain Object in-place */
    function prune(o) {
        if (!o) return;
        if (o instanceof Array) {
            o.length = 0;
        } else {
            for (var k in o) {
                delete o[k];
            }
        }
    }

    /* simple “foreach” - fn(element, index) */
    function iterate(arr, fn) {
        for (var i = 0; i < arr.length; ++i) {
            fn(arr[i], i);
        }
    }

    /* -----------------------------------------------------------
     *  Compiler start / end hooks
     * -------------------------------------------------------- */

    $$parser.start = function () {

        /* reset per-compilation state */
        if (!$$parser.stock) $$parser.stock = { '%': [], '<': [] };
        if (!$$parser.counters) $$parser.counters = { '%': 0, '<': 0 };
        if (!$$parser.metacode) $$parser.metacode = [];
        if (!$$parser.symbols) $$parser.symbols = {};
        if (!$$parser.strings) $$parser.strings = { s: [], a: [] };
        if (!$$parser.switchStack) $$parser.switchStack = [];

        /* clear transient pools and counters */
        var poolPercent = $$parser.stock['%'] || ($$parser.stock['%'] = []);
        var poolAngle   = $$parser.stock['<'] || ($$parser.stock['<'] = []);
        resetQueue(poolPercent);
        resetQueue(poolAngle);
        $$parser.counters['%'] = 0;
        $$parser.counters['<'] = 0;

        /* wipe accumulated meta-instructions */
        $$parser.metacode.length = 0;
        $$parser.labelCounter    = 0;
        $$parser.switchStack.length = 0;

        /* reset symbol tables */
        $$parser.symbols.locals   = {};
        $$parser.symbols.globals  = {};
        $$parser.symbols.functions = {};
        $$parser.symbols.defines  = {};
        $$parser.structs          = {};
        $$parser.functypes        = {};
        $$parser.exportNext       = false;

        /* reset deferred string tables */
        $$parser.strings.s = [];
        $$parser.strings.s.rlookup = {};
        $$parser.strings.a = [];
        $$parser.strings.a.rlookup = {};

        $$parser.noForward = false;

        /* random-id seeding */
        if (typeof hostRandomId !== 'undefined') {
            $$parser.randomId = hostRandomId;
        } else {
            for (var i = 0; i < 1000; ++i) {
                $$parser.randomId =
                    floor(random() * 0xFFFFFFFF) ^ time();
            }
        }

        /* banner */
        var LF = '\n';
        output('; Compiled with Impala version ' +
               $$parser.IMPALA_VERSION + LF);
        output('; signatures version=1');
    };

    $$parser.end = function () {

        /* dump deferred string literals */
        iterate($$parser.strings.s, function (rec) {
            $$parser.dumpString(rec.name, rec.data);
        });

        /* dump assert strings only if present */
        if ($$parser.strings.a.length > 0) {

            output('\t! EQUi #DEBUG #0 @.noAssertStrings');

            iterate($$parser.strings.a, function (rec) {
                $$parser.dumpString(rec.name, rec.data);
            });

            output('.noAssertStrings:\t!');
        }
    };
}

#################
#    Grammar    #
#################

root        <-  _                                                     { $$parser.start(); }
                (ImportDecl / ExportDecl / FuncDecl / StructDecl / FuncTypeDecl / ExternDecl / ConstDecl
                / GlobalDecl / ';'_)* !.                              { $$parser.end(); }

# `import "path"` names a unit for the builder's link closure. The compiler itself treats it
# as a no-op - `impala build` resolves the closure, concatenates the sources, and compiles the
# whole program at once, so the import directives are already satisfied by that point.
ImportDecl  <-  IMPORT _ path:StringLiteral _

# An `export` prefix marks a definition host-visible (Step 5). It rides the `; signature`
# metadata as a role prefix and is only load-bearing under the builder's `--dead-strip`.
ExportDecl  <-  EXPORT _                                              { $$parser.exportNext = true; }
                (FuncDecl / GlobalDecl / ConstDecl)                   { $$parser.exportNext = false; }

# ------------------------------------------------------------------
#  struct definition
# ------------------------------------------------------------------
StructDecl  <-  STRUCT _ id:Identifier                               { $sname = $id; $$parser.beginStruct($id, $$s, $$i); }
                '{' _
                ( f:(ArrayDecl / VarDecl)                            {
                                                                         $$parser.addStructField($sname,
                                                                             { name: $f.name, type: $f.type, elem: $f.elem,
                                                                               struct: $f.struct, size: $f.size },
                                                                             $$s, $$i);
                                                                     }
                  ( ';' _ )?
                )*
                '}' _                                                { $$parser.endStruct($sname); }

# ------------------------------------------------------------------
#  named function-pointer type   (Impala 2 Step 3)
#    functype Name(params) [returns t1, t2, ...]
#  Emits nothing - it only registers a signature usable as a base type.
# ------------------------------------------------------------------
FuncTypeDecl <- FUNCTYPE _ id:Identifier                             { $ftname = $id; $$parser.beginFuncType($id, $$s, $$i); }
                '(' _
                ( p:TypeDeclr                                        { $$parser.addFuncTypeParam($ftname, $p.type, $p.elem, $p.struct, $p.words, $p.name); }
                  ( ',' _ p:TypeDeclr                                { $$parser.addFuncTypeParam($ftname, $p.type, $p.elem, $p.struct, $p.words, $p.name); }
                  )*
                )?
                ')' _
                ( RETURNS _ r:TypeDeclr                              { $$parser.addFuncTypeReturn($ftname, $r.type, $r.elem, $r.struct, $r.words, $$s, $$i); }
                  ( ',' _ r:TypeDeclr                                { $$parser.addFuncTypeReturn($ftname, $r.type, $r.elem, $r.struct, $r.words, $$s, $$i); }
                  )*
                )?                                                   { $$parser.endFuncType($ftname); }

# A type with optional variable name (funcptr-type params & returns allow types-only).
TypeDeclr   <-  base:TypeBase                                        { $desc = $base; }
                ( POINTER _                                          { $desc = 'p:' + $desc; }
                )*
                ( id:Identifier                                      { $$.name = $id; }
                )?                                                   {
                                                                         var head = $$parser.descHead($desc);
                                                                         var tail = $$parser.descTail($desc);
                                                                         if (tail === undefined && $$parser.isStructAtom(head)) {
                                                                             $$.type = 'S'; $$.struct = head; $$.elem = undefined;
                                                                             $$.words = $$parser.structWords(head);
                                                                         } else if (tail === undefined && $$parser.isFuncTypeAtom(head)) {
                                                                             $$.type = 'F'; $$.elem = head; $$.struct = undefined; $$.words = 1;
                                                                         } else {
                                                                             $$.type = head; $$.elem = tail; $$.struct = undefined; $$.words = undefined;
                                                                         }
                                                                     }

# ------------------------------------------------------------------
#  function declaration
# ------------------------------------------------------------------
FuncDecl    <-  FUNCTION _ id:Identifier '('_                         {
                                                                         assert($$parser.validateStock('%'));
                                                                         assert($$parser.validateStock('<'));

                                                                         output('');
                                                                         output(';-----------------------------------------------------------------------------');

                                                                         /* declare the function symbol */
                                                                         $$parser.declare(
                                                                             undefined,
                                                                             'functions',
                                                                             $id,
                                                                             'U',
                                                                             true,
                                                                             undefined,
                                                                             $$s, $$i
                                                                         );
                                                                         var entry = $$parser.symbols.functions[$id];
                                                                         if (entry) {
                                                                             if (!entry.signature) {
                                                                                 entry.signature = {};
                                                                             }
                                                                             entry.signature.params = [];
                                                                             entry.signature.returns = '?';
                                                                             entry.signature.returnElem = undefined;
                                                                             entry.signature.returnName = undefined;
                                                                             entry.signature.sourceCode = $$s;
                                                                             entry.signature.sourceOffset = $$i;
                                                                             entry.signature.sourceName = $$parser.sourceName;
                                                                             entry.signature.returnResolved = false;
                                                                             entry.pendingReturnPlaceholder = undefined;
                                                                             entry.pendingReturnDeclaration = undefined;
                                                                         }
                                                                     }
inp:ArgsDecl ')'_
(
                    RETURNS _ out:VarDecl                             {
                                                                         var entry = $$parser.symbols.functions[$id];
                                                                         if (entry) {
                                                                             entry.pendingReturns = undefined;
                                                                             $$parser.addReturn(entry, $out.name, $out.type, $out.elem, $out.size, $$s, $$i, $out.struct, $out.words);
                                                                         }
                                                                     }
                    ( ',' _ v:VarDecl                                 {
                                                                         var entry = $$parser.symbols.functions[$id];
                                                                         if (entry) $$parser.addReturn(entry, $v.name, $v.type, $v.elem, $v.size, $$s, $$i, $v.struct, $v.words);
                                                                     }
                    )*
                                                                     {
                                                                         var entry = $$parser.symbols.functions[$id];
                                                                         if (entry && entry.signature) {
                                                                             var rl = entry.pendingReturns;
                                                                             entry.signature.returnList = rl;
                                                                             entry.signature.returnCount = rl.length;
                                                                             entry.signature.returns = rl[0].type;
                                                                             entry.signature.returnElem = rl[0].elem;
                                                                             entry.signature.returnName = rl[0].rawName;
                                                                             entry.signature.returnStruct = rl[0].struct;
                                                                             var _rw = 0;                    /* total output-window words (struct returns span >1) */
                                                                             for (var _wi = 0; _wi < rl.length; ++_wi)
                                                                                 _rw += (rl[_wi].type === 'S' ? rl[_wi].words : 1);
                                                                             entry.signature.returnWords = _rw;
                                                                             $$parser.resolveFunctionReturnType($id, rl[0].type, $$s, $$i);
                                                                         }
                                                                     }
                    /
                                                                    {
                                                                        /* implicit 1-word return: even void functions expose
                                                                           a single-word PARA so legacy call sites keep a
                                                                           deterministic return slot and the JSPEG output
                                                                           matches the historical PPEG layout. */
								var entry = $$parser.symbols.functions[$id];
								if (entry) {
									entry.pendingReturns = undefined;
									entry.pendingReturnPlaceholder = {
										sourceCode: $$s,
										sourceOffset: $$i
									};
								}
								if (entry && entry.signature) {
									entry.signature.returns = '?';
									entry.signature.returnElem = undefined;
									entry.signature.returnName = undefined;
									entry.signature.returnCount = 0;
									entry.signature.returnList = [];
									$$parser.resolveFunctionReturnType($id, '?', $$s, $$i);
								}
                                                                     }
                )                                                     {
                                                                         /* declare input parameters */
                                                                         var entry = $$parser.symbols.functions[$id];
                                                                         if (entry && entry.signature) {
                                                                             entry.signature.params = [];
                                                                             for (var idx = 0; idx < $inp.n; ++idx) {
                                                                                 var param = $inp[idx];
                                                                                 entry.signature.params.push({
                                                                                     type: param.type,
                                                                                     elem: param.elem,
                                                                                     name: param.name,
                                                                                     size: param.size,
                                                                                     struct: param.struct,
                                                                                     words: param.words
                                                                                 });
                                                                             }
                                                                         }
                                                                $$parser.emitFunctionSignature($id);
                                                                if (entry) {
                                                                        if (entry.pendingReturns && entry.pendingReturns.length > 0) {
                                                                                for (var _ri = 0; _ri < entry.pendingReturns.length; ++_ri) {
                                                                                        var ret = entry.pendingReturns[_ri];
                                                                                        if (ret.type === 'S') {  /* by-value struct return -> leading output PARA *sizeof (a writable place) */
                                                                                                $$parser.declare(
                                                                                                        'PARA', 'locals',
                                                                                                        ret.name,
                                                                                                        'S',
                                                                                                        false,
                                                                                                        '*' + ret.words,
                                                                                                        ret.sourceCode,
                                                                                                        ret.sourceOffset,
                                                                                                        undefined,
                                                                                                        ret.struct
                                                                                                );
                                                                                        } else {
                                                                                                $$parser.declare(
                                                                                                        'OUT?', 'locals',
                                                                                                        ret.name,
                                                                                                        ret.type,
                                                                                                        false,
                                                                                                        ret.size,
                                                                                                        ret.sourceCode,
                                                                                                        ret.sourceOffset,
                                                                                                        undefined,
                                                                                                        ret.elem
                                                                                                );
                                                                                        }
                                                                                }
                                                                                entry.pendingReturns = undefined;
                                                                        } else if (entry.pendingReturnPlaceholder) {
                                                                                var placeholder = entry.pendingReturnPlaceholder;
                                                                                $$parser.declare(
                                                                                        'PARA', 'locals',
                                                                                        undefined, '?',
                                                                                        false, '*1',
                                                                                        placeholder.sourceCode,
                                                                                        placeholder.sourceOffset
                                                                                );
                                                                                entry.pendingReturnPlaceholder = undefined;
                                                                        }
                                                                }
                                                                         iterate($inp, function (p) {
                                                                             if (p.type === 'S') {         /* by-value struct param -> labeled input PARA *sizeof (read-only place) */
                                                                                 $$parser.declare(
                                                                                     'PARA', 'locals',
                                                                                     '$' + p.name,
                                                                                     'S',
                                                                                     true,
                                                                                     '*' + p.words,
                                                                                     $$s, $$i,
                                                                                     undefined,
                                                                                     p.struct
                                                                                 );
                                                                             } else {
                                                                                 $$parser.declare(
                                                                                     'INP?', 'locals',
                                                                                     '$' + p.name,
                                                                                     p.type,
                                                                                     true,
                                                                                     (p.size !== undefined ? '*' + p.size : undefined),
                                                                                     $$s, $$i,
                                                                                     undefined,
                                                                                     p.elem
                                                                                 );
                                                                             }
                                                                         });
                                                                     }
                (
                    LOCALS _ loc:LocalsDecl                           {
                                                                         iterate($loc, function (v) {
                                                                             if (v.type === 'S') {         /* struct value local -> LOCA *sizeof, remember struct */
                                                                                 $$parser.declare(
                                                                                     'LOCA', 'locals',
                                                                                     '$' + v.name,
                                                                                     'S',
                                                                                     false,
                                                                                     '*' + v.words,
                                                                                     $$s, $$i,
                                                                                     undefined,
                                                                                     v.struct
                                                                                 );
                                                                             } else {
                                                                                 $$parser.declare(
                                                                                     'LOC?', 'locals',
                                                                                     '$' + v.name,
                                                                                     v.type,
                                                                                     false,
                                                                                     (v.words !== undefined ? '*' + v.words : undefined),
                                                                                     $$s, $$i,
                                                                                     undefined,
                                                                                     v.elem,
                                                                                     v.dims
                                                                                 );
                                                                             }
                                                                         });
                                                                     }
                )?                                                    { output(';-----------------------------------------------------------------------------'); }
                Block                                                 {
                                                                         /* wrap-up body */
                                                                         $$parser.processBranches();
                                                                         $$parser.emit('--^', undefined, undefined, undefined, undefined);
                                                                         $$parser.flushMetaCode('\t');

                                                                         prune($$parser.symbols.locals);
                                                                         $$parser.labelCounter = 0;

                                                                         output('');
                                                                     }
ExternDecl  <-  EXTERN _                                              { $$.scope = 'globals'; $$.structFwd = false; }
                (
                    STRUCT _ id:Identifier                            {
                                                                         $$.structFwd = true;
                                                                         $$parser.externStruct($id, $$s, $$i);
                                                                     }
                /   (   FUNCTION                                      { $$.type  = 'U';  $$.scope = 'functions'; }
                    /   NATIVE                                        { $$.type  = 'N';  $$.scope = 'functions'; }
                    ) _ id:Identifier                                 { $$.name  = $id; }
                /                                                     { $desc = undefined; }
                    ( type:BASE_TYPE _                                { $desc = $$parser.CASTS_TO_TYPES[$type]; }
                      ( POINTER _                                     { $desc = 'p:' + $desc; }
                      )*
                    )?
                    ARRAY _ id:Identifier                             {
                                                                         $$.type = 'A';
                                                                         $$.name = $id;
                                                                         $$.elem = $desc;
                                                                     }
                /   VarDecl
                )                                                     {
                                                                        if ($$.structFwd) return true;
                                                                         $$parser.declare(
                                                                             undefined,                 // no section for extern
                                                                             $$.scope,
                                                                             $$.name,
                                                                             $$.type,
                                                                             false,                     // not readonly
                                                                             '?',
                                                                             $$s, $$i,
                                                                             undefined,
                                                                             $$.elem
                                                                         );
                                                                         if ($$.scope === 'functions') {
                                                                             var entry = $$parser.symbols.functions[$$.name];
                                                                             var signature = entry && entry.signature;

                                                                             if (entry) {
                                                                             if (!signature) {
                                                                                 signature = entry.signature = {};
                                                                             }
                                                                             if (signature.sourceName === undefined) {
                                                                                 signature.sourceName = $$parser.sourceName;
                                                                             }
                                                                             if (signature.sourceCode === undefined) {
                                                                                 signature.sourceCode = $$s;
                                                                                 signature.sourceOffset = $$i;
                                                                                 signature.sourceName = $$parser.sourceName;
                                                                             }
                                                                             signature.returnResolved = false;
                                                                        }

                                                                        var role = ($$.type === 'N' ? 'extern native' : 'extern func');
                                                                        var placeholderSignature = {
                                                                            params: [],
                                                                            returns: undefined,
                                                                            sourceName: $$parser.sourceName,
                                                                            sourceCode: $$s,
                                                                            sourceOffset: $$i,
                                                                        };
                                                                        emitStandaloneSignatureComment(
                                                                            $$parser.formatFunctionSignatureComment(
                                                                                $$.name,
                                                                                placeholderSignature,
                                                                                role,
                                                                                $$parser.sourceName,
                                                                                $$s,
                                                                                $$i
                                                                            )
                                                                        );
                                                                         } else if ($$.scope === 'globals') {
                                                                            emitStandaloneSignatureComment(
                                                                                $$parser.formatGlobalSignatureComment(
                                                                                    'GLOB',
                                                                                    $$.name,
                                                                                    $$.type,
                                                                                    $$.size,
                                                                                    'extern',
                                                                                    $$parser.sourceName,
                                                                                    $$s,
                                                                                    $$i,
                                                                                    $$.elem
                                                                                )
                                                                            );
                                                                        }
                                                                    }

ConstDecl   <-  CONST _ type:BASE_TYPE _                              {
                                                                         $desc = $$parser.CASTS_TO_TYPES[$type];
                                                                         $nf = $$parser.noForward;
                                                                         $$parser.noForward = true;
                                                                     }
                 ( POINTER _                                          { $desc = 'p:' + $desc; }
                 )*
                                                                      {
                                                                         $t     = $$parser.descHead($desc);
                                                                         $telem = $$parser.descTail($desc);
                                                                      }
                 id:Identifier
                 (   '=' _ x:Expr                                     {
                                                                            $$parser.declare(
                                                                                '! DEF?', 'defines',
                                                                                $id, $t, true,
                                                                                $$parser.makeConstant($x, $t, $$s, $$i),
                                                                                $$s, $$i,
                                                                                $$parser.formatConstSignatureComment(
                                                                                    $id,
                                                                                    $t,
                                                                                    $$parser.sourceName,
                                                                                    $$s,
                                                                                    $$i,
                                                                                    $telem
                                                                                ),
                                                                                $telem
                                                                            );
                                                                         }
                 /                                                     {
                                                                             $$parser.declare(
                                                                                 undefined, 'defines',
                                                                                 $id, $t, true,
                                                                                 undefined,
                                                                                 $$s, $$i,
                                                                                 undefined,
                                                                                 $telem
                                                                             );
                                                                         }
                 )                                                     { $$parser.noForward = $nf; }

GlobalDecl  <-  (   GLOBAL                                            { $section = 'GLOB'; }
                 /  READONLY                                          { $section = 'CNST'; }
                 /  TEMPORARY                                         { $section = 'TEMP'; }
                 ) _
                 (
                     # primitive variable --------------------------------
                     v:VarDecl                                        {
                                                                             $vStruct = ($v.type === 'S');
                                                                             if ($vStruct) {              /* struct value global -> one zeroed GLOB/CNST/TEMP *sizeof */
                                                                                 $$parser.declare(
                                                                                     $section, 'globals',
                                                                                     $v.name, 'S',
                                                                                     ($section === 'CNST'),
                                                                                     '*' + $v.words,
                                                                                     $$s, $$i,
                                                                                     $$parser.formatGlobalSignatureComment(
                                                                                         $section, $v.name, 'S', undefined, undefined,
                                                                                         $$parser.sourceName, $$s, $$i, $v.struct),
                                                                                     $v.struct
                                                                                 );
                                                                             } else {
                                                                                 $$parser.declare(
                                                                                     $section, 'globals',
                                                                                     undefined,
                                                                                     $v.type,
                                                                                     ($section === 'CNST'),
                                                                                     '*1',
                                                                                     $$s, $$i
                                                                                 );
                                                                                 $init = $$parser.ZEROES[$v.type];
                                                                             }
                                                                         }
                         ( '=' _
                           ( d:Braced                              {
                                                                             if (!$vStruct)
                                                                                 $$parser.fail('Brace initializers are only for struct values',
                                                                                         $$s, $$i, 'E422');
                                                                             $binit = [];
                                                                             $$parser.buildStructInit($v.struct, $d, $binit, $$s, $$i);
                                                                             $$parser.emitInitData($binit, $$s, $$i);
                                                                         }
                           / x:Expr                                 {
                                                                             if ($vStruct)
                                                                                 $$parser.fail('A struct value needs a brace initializer',
                                                                                         $$s, $$i, 'E421');
                                                                             $init = $$parser.makeConstant($x, $v.type, $$s, $$i);
                                                                         }
                           ) )?
                                                                       {
                                                                            if (!$vStruct)
                                                                            $$parser.declare(
                                                                                'DAT?', 'globals',
                                                                                $v.name,
                                                                                $v.type,
                                                                                ($section === 'CNST'),
                                                                                $init,
                                                                                $$s, $$i,
                                                                                $$parser.formatGlobalSignatureComment(
                                                                                    $section,
                                                                                    $v.name,
                                                                                    $v.type,
                                                                                    undefined,
                                                                                    undefined,
                                                                                    $$parser.sourceName,
                                                                                    $$s,
                                                                                    $$i,
                                                                                    $v.elem
                                                                                ),
                                                                                $v.elem
                                                                            );
                                                                         }

                   / # array ----------------------------------------------
                     a:ArrayDecl                                      {
                                                                            $$parser.declare(
                                                                                $section, 'globals',
                                                                                $a.name,
                                                                                'A',
                                                                                ($section === 'CNST'),
                                                                                '*' + $a.words,
                                                                                $$s, $$i,
                                                                                $$parser.formatGlobalSignatureComment(
                                                                                    $section,
                                                                                    $a.name,
                                                                                    'A',
                                                                                    $a.size,
                                                                                    undefined,
                                                                                    $$parser.sourceName,
                                                                                    $$s,
                                                                                    $$i,
                                                                                    $a.elem,
                                                                                    $a.dims
                                                                                ),
                                                                                $a.elem,
                                                                                $a.dims
                                                                            );
                                                                            $aStructEl = ($a.elem !== undefined
                                                                                    && $$parser.descTail($a.elem) === undefined
                                                                                    && $$parser.isStructAtom($$parser.descHead($a.elem)));
                                                                            $aStruct = $a.elem;
                                                                            $aCount = parseInt('' + $a.size, 10);
                                                                         }
                         ( '=' _
                           ( d:InitList                                {   /* flat list -> scalar-element arrays only */
                                                                            if ($aStructEl)
                                                                                $$parser.fail('A struct-element array needs nested braces, one group per element',
                                                                                        $$s, $$i, 'E422');
                                                                         }
                           / d:Braced                                  {   /* nested braces -> struct-element arrays */
                                                                            if (!$aStructEl)
                                                                                $$parser.fail('Nested brace initializers are for struct-element arrays',
                                                                                        $$s, $$i, 'E422');
                                                                            var _arr = $d;
                                                                            $binit = [];
                                                                            for (var _ae = 0; _ae < $aCount; ++_ae) {
                                                                                var _aev = (_ae < _arr.length) ? _arr[_ae] : undefined;
                                                                                $$parser.buildStructInit($aStruct,
