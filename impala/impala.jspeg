# ------------------------------------------------------------------
#  Initialiser list for arrays                                  
# ------------------------------------------------------------------
# Nested brace tree of compile-time constants, for struct initializers.
Braced      <-  '{' _                                                { $$ = []; $$.n = 0; }
                ( i:BracedItem                                       { $$[$$.n++] = $i; }
                  ( ',' _ i:BracedItem                               { $$[$$.n++] = $i; }
                  )*
                )? '}' _

BracedItem  <-  b:Braced                                             { $$ = { braced: $b }; }
                / x:Expr                                             {
                                                                        var m = metaSlot($x);
                                                                        var op = $$parser.makeRValue(m, '#<&');
                                                                        if (span(op[0] || '', '#<&') !== 1)
                                                                            $$parser.fail('Initializer must be a constant', $$s, $$i, 'E407');
                                                                        $$ = { op: op, type: m.type };
                                                                    }

InitList    <-  '{' _                                                 { $d = ' '; $type = undefined; }
                ( x:Expr                                             {
                                                                            var xMeta = metaSlot($x);
                                                                            $type = xMeta.type;
                                                                            $d += $$parser.makeConstant(xMeta, $type, $$s, $$i);
                                                                        }
                  ( ',' _ x:Expr                                     {
                                                                            var xMeta = metaSlot($x);
                                                                            var xType = xMeta.type;
                                                                            var constant = $$parser.makeConstant(xMeta, xType, $$s, $$i);

                                                                            /* decide if we need to flush DATA */
                                                                            if (  constant[0] === '<'
                                                                              || $d[1] === '<'
                                                                              || ($d + ' ' + constant).length >= 55) {

                                                                                $$parser.declare(
                                                                                    'DATA', 'globals',
                                                                                    undefined, xType,
                                                                                    true, $d.substr(1),
                                                                                    $$s, $$i
                                                                                );
                                                                                $d = '';
                                                                            }
                                                                            $d += ' ' + constant;
                                                                            $type = xType;
                                                                        }
                  )* )?
              '}' _                                                  {
                                                                        if ($d.substr(1) !== '') {
                                                                            $$parser.declare(
                                                                                'DATA', 'globals',
                                                                                undefined, $type,
                                                                                true, $d.substr(1),
                                                                                $$s, $$i
