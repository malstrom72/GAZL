                                                                        }
                                                                    }

# ------------------------------------------------------------------
#  Parameter & local-variable helper lists                      
# ------------------------------------------------------------------
ArgsDecl    <-                                                        {
                                                                         $$ = [];
                                                                         $$.n = 0;
                                                                     }
                 ( v:VarDecl                                          {
                                                                             var entry = {};
                                                                             entry.type = $v.type;
                                                                             entry.elem = $v.elem;
                                                                             entry.struct = $v.struct;
                                                                             entry.words = $v.words;
                                                                             entry.name = $v.name;
                                                                             entry.size = $v.size;
                                                                             entry.dims = $v.dims;
                                                                             $$[$$.n++] = entry;
                                                                         }
                   ( ',' _ v:VarDecl                                  {
                                                                             var entry = {};
                                                                             entry.type = $v.type;
                                                                             entry.elem = $v.elem;
                                                                             entry.struct = $v.struct;
                                                                             entry.words = $v.words;
                                                                             entry.name = $v.name;
                                                                             entry.size = $v.size;
                                                                             entry.dims = $v.dims;
                                                                             $$[$$.n++] = entry;
                                                                         }
                   )*
                 )?

LocalsDecl  <-                                                        {
                                                                         $$ = [];
                                                                         $$.n = 0;
                                                                     }
                 ( v:(VarDecl / ArrayDecl)                            {
                                                                             var entry = {};
                                                                             entry.type = $v.type;
                                                                             entry.elem = $v.elem;
                                                                             entry.struct = $v.struct;
                                                                             entry.words = $v.words;
                                                                             entry.name = $v.name;
                                                                             entry.size = $v.size;
                                                                             entry.dims = $v.dims;
                                                                             $$[$$.n++] = entry;
                                                                         }
                   ( ',' _ v:(VarDecl / ArrayDecl)                    {
                                                                             var entry = {};
                                                                             entry.type = $v.type;
                                                                             entry.elem = $v.elem;
                                                                             entry.struct = $v.struct;
                                                                             entry.words = $v.words;
                                                                             entry.name = $v.name;
                                                                             entry.size = $v.size;
                                                                             entry.dims = $v.dims;
                                                                             $$[$$.n++] = entry;
