                                                       var callResultType = '?';
                                                       var signature = null;
                                                       var calleeName = null;

                                                       if (span(callee.type, 'FN') !== 1) {
                                                           $$parser.typeError(
                                                               'Invalid type for function call ({$type1})',
                                                               $$s, $$i, callee.type
                                                           , undefined, 'E408');
                                                       }

                                                       if (callee.operator === ':=' &&
                                                           callee.operands[1] &&
                                                           (callee.operands[1][0] === '&' ||
                                                            callee.operands[1][0] === '^')) {
                                                           calleeName = callee.operands[1].substr(1);
                                                           var entry = $$parser.symbols.functions[calleeName];
                                                           if (entry && entry.kind === 'FUNC' && entry.signature) {
                                                               signature = entry.signature;
                                                           }
                                                       } else if (callee.type === 'F' && $$parser.isFuncTypeAtom(callee.elem)) {
                                                           signature = $$parser.functypes[callee.elem];   /* indirect call: check against the funcptr type */
                                                       }

                                                       if (signature && signature.returnCount > 1 && !$$parser.destructuring) {
                                                           $$parser.fail('Function ' + (calleeName || 'this call')
                                                                   + ' returns ' + signature.returnCount
                                                                   + ' values; destructure the call (a, b = ' + (calleeName || 'f') + '(...))',
