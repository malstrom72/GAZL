                                                                     '*' + ($$.words + $$.retSlots));
                                                       $$parser.returnBack(func);

                                                       while ($$.words-- > 0) {              /* free the argument words (past the output slots) */
                                                           $$parser.returnBack('%' + ($$.base + $$.retSlots + $$.words));
                                                       }

                                                       $$parser.makeMeta(callee, ':=', callResultType,
                                                                         undefined,
                                                                         '%' + $$.base,
                                                                         undefined);
                                                       $$parser.setElem(callee, undefined);
                                                       if (signature && signature.returns === 'S') {   /* by-value struct return -> a place over the output window */
                                                           var _wp = $$parser.borrow('%');
                                                           $$parser.emit('=&', 'p', _wp, '%' + $$.base, '*' + $$.retSlots);
                                                           $$parser.setPlace(callee, 'pointer', _wp, 0, signature.returnStruct);
