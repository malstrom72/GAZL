# this one works (except actions and vars), but is slow with:
#
#  . [a-z] (should create expressions instead of indexOf)
#  . creating millions of anonymous functions every single time it needs a new local var
#  . parsing through shared _i, perhaps we can return i instead (and < 0 is false?)

{
        function $$parser.dqEscape(s) {
                return JSON.stringify(s);
        }

        function $$parser.hasOwn(obj, key) {
                return Object.prototype.hasOwnProperty.call(obj, key);
        }
}

# ----------------------------------------------------------------------------------------------------------------------

root		<-								{
												$fn = "(function(_s) {\n";
											}
				( Spacing b=PikaBlock		{ $fn += $b.replace(/\x24\x24parser\./g, '') + ';' }
				)? Spacing g:Grammar		{
												$fn += $g;
												$fn += "var _i=0,_im=0,_o={_:void 0},_b=root(_o);\n";
												$fn += "return [_b,_o._,(_b?_i:_im)];\n})\n";
												$$ = $fn;
											}

# ----------------------------------------------------------------------------------------------------------------------


#############################
#    Hierarchical syntax    #
#############################


# ----------------------------------------------------------------------------------------------------------------------

Grammar		<-								{ $$ = '' }
				Spacing ( d:Definition		{ $$ += $d + ";\n" }
				)* EndOfFile

# ----------------------------------------------------------------------------------------------------------------------

Definition	<-	id:Identifier LEFTARROW		{ $$.tag = '$'; $$.vi = 0; $$.vr = $vars = {} }
					Expression				{
												var _v = '';
                                                                                                for (var _k in $vars) {
                                                                                                        if (hasOwn($vars, _k)) {
                                                                                                                _v += (_v !== '' ? ',' : '') + _k + $vars[_k];
                                                                                                        }
                                                                                                }
												$$ = 'function ' + $id + '($){' + (_v === '' ? '' : ('var ' + _v + ';'))
													+ 'return ' + $$ + '}'
											}

# ----------------------------------------------------------------------------------------------------------------------

Expression	<-								{ $s.vi = $$.vi + 1; $s.tag = $$.tag; $s.vr = $$.vr; $$ = '' }
				s:Sequence					{ $$ = $s }
				( SLASH s:Sequence			{ $$ += '||' + $s }
				)*							{ $$ = '(function(){var _b=_i;return ' + $$ + '})()' }

# ----------------------------------------------------------------------------------------------------------------------

Sequence	<-								{ $p.vi = $$.vi; $p.tag = $$.tag; $p.vr = $$.vr; $$ = '' }
				( p:(Prefix / Action)		{ $$ += ($$ !== '' ? '&&' : '') + $p }
				)*							{ $$ += ($$ === '' ? 'true' : '||(_im=(_i>_im?_i:_im),_i=_b,false)') }

# ----------------------------------------------------------------------------------------------------------------------

Action          <-      b=PikaBlock Spacing                     {
                                                                                                $b = $b.slice(1, $b.length - 1);
                                                                                                for (var s = '(function(){'; $b.length > 0; ) {
                                                                                                  // find first of $,/,tab,CR,LF
                                                                                                  var idx = $b.search(/[$/\t\r\n]/);
                                                                                                  var cut = (idx === -1 ? $b.length : idx);
                                                                                                  s += $b.slice(0, cut);
                                                                                                  $b = $b.slice(cut);
                                                                                                  if ($b.length === 0) {
                                                                                                    continue;
                                                                                                  }

                                                                                                  if ($b[0] === '$') {
                                                                                                    if ($b.slice(0, 9) === '\x24\x24parser.') {
                                                                                                      $b = $b.slice(9);
                                                                                                    } else if ($b.slice(0, 3) === '\x24\x24s') {
                                                                                                      s += '_s';
                                                                                                      $b = $b.slice(3);
                                                                                                    } else if ($b.slice(0, 3) === '\x24\x24i') {
                                                                                                      s += '_i';
                                                                                                      $b = $b.slice(3);
                                                                                                    } else if ($b.slice(0, 2) === '\x24\x24') {
                                                                                                      s += ($b[2] === '.' ? '$' : '$._');
                                                                                                      $b = $b.slice(2);
                                                                                                    } else {
                                                                                                      var m = $b.slice(1).match(/^[A-Za-z_]+/);
                                                                                                      var e = (m ? m[0].length : 0) + 1;
                                                                                                      var id = $b.slice(0, e);
                                                                                                      s += id;
                                                                                                      $b = $b.slice(e);
                                                                                                      if (!hasOwn($$.vr, id)) {
                                                                                                        $$.vr[id] = '';
                                                                                                      } else if ($$.vr[id] !== '' && $b[0] !== '.') {
                                                                                                        s += '._';
                                                                                                      }
                                                                                                    }
                                                                                                  } else if ($b.slice(0, 2) === '//') {
                                                                                                    var newline = $b.indexOf('\n');
                                                                                                    var span = (newline === -1 ? $b.length : newline + 1);
                                                                                                    s += $b.slice(0, span);
                                                                                                    $b = $b.slice(span);
                                                                                                  } else if ($b[0] === '/') {
                                                                                                    s += '/';
                                                                                                    $b = $b.slice(1);
                                                                                                  } else {
                                                                                                    if (s[s.length - 1] !== ' ') s += ' ';
                                                                                                    var ws = $b.match(/^[ \t\r\n]+/);
                                                                                                    $b = $b.slice(ws ? ws[0].length : 0);
                                                                                                  }
                                                                                                }

                                                                                                $$ = s + '; return true})()';
                                                                                        }
												
# ----------------------------------------------------------------------------------------------------------------------

Prefix		<-								{ $c.vi = $$.vi; $c.tag = $$.tag; $c.vr = $$.vr }
				AND c:Capture				{ $$ = '(function(){var _l=_i' + ',_x=' + $c + ';_i=_l;return _x})()' }
				/ NOT c:Capture				{ $$ = '(function(){var _l=_i' + ',_x=' + $c + ';_i=_l;return !_x})()' }
				/ Capture

# ----------------------------------------------------------------------------------------------------------------------

Capture		<-	v:Variable EQUALS			{ if ($v !== '$._') $$.vr[$v] = ''; }
						Tagged				{ $$ = '(function(){var _m=_i;return ' + $$ + '&&(' + $v + '=_s.slice(_m,_i),true)})()' }
				/ Tagged

# ----------------------------------------------------------------------------------------------------------------------

Tagged		<-	v:Variable COLON			{ $t.vi = $$.vi; if ($v !== '$._') { $t.tag = $v; ($t.vr = $$.vr)[$v] = '={}' } else $t.tag = '$' }
					t:Suffix				{ $$ = $t }
				/ Suffix
				
# ----------------------------------------------------------------------------------------------------------------------

Suffix		<-	Primary ( QUESTION			{ $$ = '(' + $$ + ',true)' }
						  / STAR			{ $$ = '((function(){while(' + $$ + ');})(),true)' }
						  / PLUS			{ $$ = '((function(){for(var _n=0;' + $$ + ';++_n);return _n>0})())' }
				)?

# ----------------------------------------------------------------------------------------------------------------------

Primary		<-	Identifier !LEFTARROW		{ $$ += '(' + $$.tag + ')' }
				/ Literal					{
												var l = ($$).length;
												if (l == 0) $$ = 'true';
												else if (l == 1) $$ = '(_s[_i]===' + $$parser.dqEscape($$) + ')&&(++_i,true)';
												else $$ = '(_s.substr(_i,' + l + ')===' + $$parser.dqEscape($$)
														+ ')&&(_i+=' + l + ',true)';
											}
				/ Class						{ $$ = '(!!_s[_i]&&' + $$parser.dqEscape($$) + '.indexOf(_s[_i])>=0)&&(++_i,true)' }
				/ DOT						{ $$ = '(!!_s[_i])&&(++_i,true)' }
				/ OPEN Expression CLOSE

# ----------------------------------------------------------------------------------------------------------------------


########################
#    Lexical syntax    #
########################


# ----------------------------------------------------------------------------------------------------------------------

Identifier	<-	$$=(IdentStart IdentCont*) Spacing

# ----------------------------------------------------------------------------------------------------------------------

IdentStart	<-	[a-zA-Z_]

# ----------------------------------------------------------------------------------------------------------------------

IdentCont	<-	IdentStart / [0-9] 

# ----------------------------------------------------------------------------------------------------------------------

Variable	<-	( '$$'						{ $$ = '$._' }
				  / $$=PikaVar				{ $$ = '$' + $$ }
				) Spacing

# ----------------------------------------------------------------------------------------------------------------------

Literal		<-								{ $$ = '' }
				['] ( !['] c:Char			{ $$ += $c }
				)* ['] Spacing
				/ ["] ( !["] c:Char			{ $$ += $c }
				)* ["] Spacing

# ----------------------------------------------------------------------------------------------------------------------

Class		<-								{ $$ = '' }
				'[' ( !']' r:Range			{ $$ += $r }
				)* ']' Spacing

# ----------------------------------------------------------------------------------------------------------------------

Range		<-	f:Char '-' t:Char			{ $$ = ''; for (var i = ($f).charCodeAt(0), e = ($t).charCodeAt(0); i <= e; ++i) $$ += String.fromCharCode(i); }
				/ $$:Char

# ----------------------------------------------------------------------------------------------------------------------

Char		<-	"\\" x=[nrt'"\[\]\\]		{ $$ = "\n\r\t'\"[]\\"[("nrt'\"[]\\").indexOf($x)] }
				/ "\\" x=([0-3][0-7][0-7])	{ $$ = String.fromCharCode($x[0] * 64 + $x[1] * 8 + +$x[2]) }
				/ "\\" x=([0-7][0-7])		{ $$ = String.fromCharCode($x[0] * 8 + +$x[1]) }
				/ "\\" x=([0-7])			{ $$ = String.fromCharCode(+$x[0]) }
				/ ![\\\0-\37] $$=.

# ----------------------------------------------------------------------------------------------------------------------

Spacing		<-	(Space / Comment)*

# ----------------------------------------------------------------------------------------------------------------------

Comment		<-	'#' (!EndOfLine .)*
				(EndOfLine / EndOfFile)

# ----------------------------------------------------------------------------------------------------------------------

Space		<-	' ' / "\t" / EndOfLine

# ----------------------------------------------------------------------------------------------------------------------

EndOfLine	<-	"\r\n" / "\n" / "\r"

# ----------------------------------------------------------------------------------------------------------------------

EndOfFile	<-	!.

# ----------------------------------------------------------------------------------------------------------------------


#################
#    Actions    #
#################


# ----------------------------------------------------------------------------------------------------------------------

PikaVar		<-	[a-zA-Z_] ('.'? [a-zA-Z$_0-9])*

# ----------------------------------------------------------------------------------------------------------------------

PikaBlock	<-	'{' ( &'{' PikaBlock
					/ &["'] PikaString
					/ &('/*' / '//') PikaComment
					/ !'}' .
					)* '}'

# ----------------------------------------------------------------------------------------------------------------------

PikaString	<-	'"' ( ('\\' / !'"') . )* '"'
				/ "'" ( ("''" / !"'" .) )* "'"

# ----------------------------------------------------------------------------------------------------------------------

PikaComment	<-	'/*' (!'*/' .)* '*/'
				/ "//" (!EndOfLine .)* (EndOfLine / EndOfFile)

# ----------------------------------------------------------------------------------------------------------------------


################
#    Tokens    #
################


# ----------------------------------------------------------------------------------------------------------------------

LEFTARROW	<-	'<-' Spacing
SLASH		<-	'/' Spacing
AND			<-	'&' Spacing
NOT			<-	'!' Spacing
QUESTION	<-	'?' Spacing
STAR		<-	'*' Spacing
PLUS		<-	'+' Spacing
OPEN		<-	'(' Spacing
CLOSE		<-	')' Spacing
DOT			<-	'.' Spacing
COLON		<-	':' Spacing
EQUALS		<-	'=' Spacing

# ----------------------------------------------------------------------------------------------------------------------
