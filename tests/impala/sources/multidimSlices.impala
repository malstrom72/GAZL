/*
	Impala 2.0 multidimensional arrays (slice 2): shape-carrying pointers and `:` slices.
	- `&a` yields an `int array[H, W] pointer`; `&a[y, :]` yields an `int array[W] pointer` (a row).
	- A shape pointer indexes with `m[y, x]` (within its shape) or walks one extra outer axis.
	- A trailing `:` slice `a[y, :]` is a contiguous sub-array; `a[y, :] = b[y, :]` copies it (COPY).
	Shapes are distinct types (int array[4] pointer != int array[5] pointer), checked by E201/E202.
	Expected (GAZLCmd multidimSlices.gazl main): 138 46 23 20.
*/

const int DEBUG = 1

extern native printInt
extern native printLF

function matsum(int array[3, 4] pointer m) returns int r		// whole-matrix pointer, index within
locals int y, int x
{
	r = 0;
	for (y = 0 to 3) { for (x = 0 to 4) { r = r + m[y, x]; } }
}

function rowsum(int array[4] pointer row) returns int r			// row pointer
locals int x
{
	r = 0;
	for (x = 0 to 4) { r = r + row[0, x]; }
}

function main()
locals int array a[3, 4], int array b[3, 4], int y, int x
{
	for (y = 0 to 3) { for (x = 0 to 4) { a[y, x] = y * 10 + x; } }
	printInt(matsum(&a)); printLF();				// 138 - whole matrix via &a
	printInt(rowsum(&a[1, :])); printLF();			// 46  - row 1 via &a[1, :]
	b[0, :] = a[2, :];								// slice-copy row 2 of a into row 0 of b
	printInt(b[0, 3]); printLF();					// 23
	printInt(b[0, 0]); printLF();					// 20
}
