/*
	Impala 2 Step 2 (slice 2): struct VALUES as locals, with nested inline fields, plus
	nested field access through a struct pointer. Struct-value field access compiles to
	direct `$v:offset` operands (no indirection — "dots are free"); pointer-based access
	folds the composed offset into a single PEEK/POKE.
	Expected when run (GAZLCmd structValues.gazl main): 60 0.5 0.1 0.9 2 0.5 1.5 2.5.
*/

const int DEBUG = 1

struct Biquad {
	float b0
	float z1
}

struct Voice {
	int note
	Biquad lo						// inline nested struct, offsets 1..2
	Biquad hi						// offsets 3..4
	float gain						// offset 5
}

extern native printInt
extern native printFloat
extern native printLF

global array store[8]

function tweak(Voice pointer v, float x)
{
	v->lo.b0 = x;					// pointer base, nested field, folded offset
	v->hi.z1 = x + 1.0;
	v->gain = x + 2.0;
}

function main()
locals Voice v, Voice pointer p
{
	v.note = 60;					// direct $v:0
	v.lo.b0 = 0.5;					// direct $v:1
	v.lo.z1 = 0.1;					// direct $v:2
	v.hi.b0 = 0.9;					// direct $v:3
	v.gain = 2.0;					// direct $v:5
	printInt(v.note); printLF();
	printFloat(v.lo.b0); printLF();
	printFloat(v.lo.z1); printLF();
	printFloat(v.hi.b0); printLF();
	printFloat(v.gain); printLF();

	p = (Voice pointer) &global store[0];
	tweak(p, 0.5);
	printFloat(p->lo.b0); printLF();
	printFloat(p->hi.z1); printLF();
	printFloat(p->gain); printLF();
}
