 addVec:			FUNC		; signature func addVec(Vec2 a, Vec2 b) -> Vec2 @ 17:17
 					$r:			PARA *2
 					$a:			PARA *2
 					$b:			PARA *2
 ;-----------------------------------------------------------------------------
 								ADDi $r:0 $a:0 $b:0				; r.x = a.x + b.x
 								ADDi $r:1 $a:1 $b:1				; r.y = a.y + b.y
 								RETU   							; }


 ;-----------------------------------------------------------------------------
 divmod:			FUNC		; signature func divmod(int a, int b) -> (int, int) @ 23:17
 					$q:			OUTi
 					$rem:		OUTi
 					$a:			INPi
 					$b:			INPi
 ;-----------------------------------------------------------------------------
 								DIVi $q $a $b					; q = a / b
 								DIVi %0 $a $b					; rem = a - a / b * b
 								MULi %0 %0 $b
 								SUBi $rem $a %0
 								RETU   							; }

