		ABSi $l %1 
		SHRi %1 $l #1	; *tp = l + (l >> 1)
		ADDi %1 $l %1
		POKE $tp %1 
		PEEK %1 $tp #1	; r = abs((int) tp[1])
		ABSi $r %1 
		SHRi %1 $r #1	; tp[1] = r + (r >> 1)
		ADDi %1 $r %1
		POKE $tp #1 %1
		PEEK %1 $tp #2	; l = abs((int) tp[2])
		ABSi $l %1 
		SHRi %1 $r #1	; tp[2] = r + (r >> 1)
		ADDi %1 $r %1
		POKE $tp #2 %1
		PEEK %1 $tp #3	; r = abs((int) tp[3])
		ABSi $r %1 
		SHRi %1 $r #1	; tp[3] = r + (r >> 1)
		ADDi %1 $r %1
		POKE $tp #3 %1
		ADDp $tp $tp #4	; tp = tp + 4
		FORi $bi <A> @.l15	; }
	.f13:	MOVi $l $tapData:TAP_LEFT_GAIN 	; l = (int) tapData[TAP_LEFT_GAIN]
		MOVi $r $tapData:TAP_RIGHT_GAIN 	; r = (int) tapData[TAP_RIGHT_GAIN]
		ADRL $tp $_tapped *0	; tp = _tapped
		PEEK %1 $tp 	; if (abs((int) *tp) > 12) ledBits = ledBits | ((int) tapData[TAP_BITS] >> 16)
		ABSi %1 %1 
		LEQi %1 #12 @.f16
		SHRi %1 $tapData:TAP_BITS #16	; ledBits = ledBits | ((int) tapData[TAP_BITS] >> 16)
		IORi $ledBits $ledBits %1
	.f16:	MOVi $bi #0 	; for (bi = 0 to BATCH_SIZE / 2) 
		! DIVi <A> #BATCH_SIZE #2
		GEQi #0 <A> @.e17
	.l18:	PEEK %1 $tp 	; *bp = (int) *bp + (int) *tp * l
		PEEK %2 $bp 
		MULi %1 %1 $l
		ADDi %2 %2 %1
		POKE $bp %2 
		PEEK %2 $tp #1	; bp[1] = (int) bp[1] + (int) tp[1] * r
		PEEK %1 $bp #1
		MULi %2 %2 $r
		ADDi %1 %1 %2
		POKE $bp #1 %1
		PEEK %1 $tp #2	; bp[2] = (int) bp[2] + (int) tp[2] * l
		PEEK %2 $bp #2
		MULi %1 %1 $l
		ADDi %2 %2 %1
		POKE $bp #2 %2
		PEEK %2 $tp #3	; bp[3] = (int) bp[3] + (int) tp[3] * r
		PEEK %1 $bp #3
		MULi %2 %2 $r
		ADDi %1 %1 %2
		POKE $bp #3 %1
		ADDp $bp $bp #4	; bp = bp + 4
		ADDp $tp $tp #4	; tp = tp + 4
		FORi $bi <A> @.l18	; }
	.e17:	ADDp $p $p #TAP_STRUCT_SIZE	; p = p + TAP_STRUCT_SIZE
		FORi $i %0 @.l12	; }
	.e11:	MOVp $bp &buffer 	; for (bp = global buffer to global buffer + BATCH_SIZE * 2) *bp = (int) *bp >> 8
		! MULi <A> #BATCH_SIZE #2
		ADDp %0 &buffer <A>
		GEQp &buffer %0 @.e19
	.l20:	PEEK %1 $bp 	; *bp = (int) *bp >> 8
		SHRi %1 %1 #8
		POKE $bp %1 
		FORp $bp %0 @.l20
	.e19:	PEEK %0 &params:OPERAND_1_LOW_PARAM_INDEX 	; global displayLEDs[1] = (int) global params[OPERAND_1_LOW_PARAM_INDEX] & (ledBits >> 8)
		SHRi %1 $ledBits #8
		ANDi %0 %0 %1
		POKE &displayLEDs:1 %0 
		PEEK %0 &params:OPERAND_2_LOW_PARAM_INDEX 	; global displayLEDs[3] = (int) global params[OPERAND_2_LOW_PARAM_INDEX] & ledBits
		ANDi %0 %0 $ledBits
		POKE &displayLEDs:3 %0 
		GOTO @.l6  	; }
	.e5:	RETU   	; }

