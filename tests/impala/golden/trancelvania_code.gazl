	.s19#0:	MULf $l $l $gainL	; l = l * gainL
		MULf $r $r $gainR	; r = r * gainR
		ADDf $gainL $gainL $gainLD	; gainL = gainL + gainLD
		ADDf $gainR $gainR $gainRD	; gainR = gainR + gainRD
		GOTO @.e20  	; }
	.s19#1:	MOVf $l $lpL 	; l = lpL
		MOVf $r $lpR 	; r = lpR
		GOTO @.e20  	; }
	.s19#2:	MOVf $l $bpL 	; l = bpL
		MOVf $r $bpR 	; r = bpR
		GOTO @.e20  	; }
	.s19#3:	MOVf $l $hpL 	; l = hpL
		MOVf $r $hpR 	; r = hpR
	.s19:	NOOP
	.e20:	fTOi %0 $l #2048.0	; global signal[0] = ftoi(l * 2048.0)
		POKE &signal:0 %0 
		fTOi %0 $r #2048.0	; global signal[1] = ftoi(r * 2048.0)
		POKE &signal:1 %0 
		CALL ^yield %0 *1	; expects yield() -> unknown @ 401:11
		ADDi $clock $clock $clockDir	; clock = clock + clockDir
		SUBf $nyquist #0.0 $nyquist	; nyquist = -nyquist
		FORi $i #BATCH_SIZE @.l18	; }
	.e17:	MOVf $gainL $valueL 	; gainL = valueL
		MOVf $gainR $valueR 	; gainR = valueR
		GOTO @.l0  	; }
		RETU   	; }

