;===============================================================================
; Check version
;===============================================================================

			! IFDF #GAZL_VERSION @gotVersion
			! FAIL GAZL_VERSION not defined!
gotVersion:	! EQUi #GAZL_VERSION #1 @versionOK
			! FAIL This code is for version 1 of GAZL only.
versionOK:	!

			! IFDF #GAZL_WORD_SIZE @gotBits
			! FAIL GAZL_WORD_SIZE not defined!
gotBits:	! EQUi #GAZL_WORD_SIZE #32 @bitsOK
			! FAIL This code is for 32-bits word size only.
bitsOK:		!

;===============================================================================
; TEST
;===============================================================================

						! MOVi <X> #0
	ZERO:				! DEFi #<X>
						! ADDi <X> <X> #1
	ONE:				! DEFi #<X>
						! ADDi <X> <X> #1
	TWO:				! DEFi #<X>

;-------------------------------------------------------------------------------
HelloString:			CNST *6
;-------------------------------------------------------------------------------
						DATs hell
	O:					DATi #'o'
						! ADDi <Y> #50 #50
						! MULi <X> <Y> #200
	TRY_ONE:			! DEFi #1
	ARRAY_SIZE:			! DEFi <X>

;-------------------------------------------------------------------------------
GlobTest:				GLOB *ARRAY_SIZE
;-------------------------------------------------------------------------------
						DATi #0x01020304
						DATi #0x01020304
						DATi #0x01020304
						DATi #0x01020304
						DATi #0x05060708
						DATi #0x05060708
						DATi #0x05060708
						DATi #0x05060708
	Nully:				DATp &NULL
	Pointy:				DATp &main
	Stringy:			DATs helloooo
						DATi #0

;-------------------------------------------------------------------------------
main:					FUNC
	out:				OUTi
;-------------------------------------------------------------------------------
	i:					LOCi
	x:					LOCi
	p:					LOCp
	p2:					LOCp
	y:					LOCf
	z:					LOCf
	asdfasdf:			LOCA *2349
	myArray:			LOCA *ARRAY_SIZE
; - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 

	test1:				MOVp p &NULL
						MOVp %1 p
						CALL ^printInt %0 *1
						CALL ^printLF
	hang:				NEQp p &NULL @hang
						PEEK %0 &Pointy:0
						EQUp p %0 @hang
						MOVf y #35.5
						MOVf y #11.5
						ADDf y  #35.5 y
						ADDf z  #35.5 #11.5
						NEQf y z @baaad
						! MOVi <X> #ARRAY_SIZE
						MOVi %0 #<X>
						ADRL %1 myArray:0 *ARRAY_SIZE
						CALL &FillRnd %0 *2
						MOVi %0 i
						ADRL p myArray:0 *ARRAY_SIZE
						MOVp %0 p
						CALL ^printLF
						CALL ^printLF
						CALL ^printLF
							
						MOVi i #0
						! SUBi <n> #ARRAY_SIZE #2
						ADRL p myArray:2 *<n>
						PEEK y p
						ADDf y y y
						POKE p y
						ADRL p myArray:0 *ARRAY_SIZE
						
						! EQUi #0 #0 @printStuff
						CALL ^abort

	printStuff:			GETL %1 myArray i
						CALL ^printFloat %0 *1
						CALL ^printLF
							
						FORi i #20 @printStuff	
						CALL ^printLF
	! ADDi <X> #32 #32
	loop#<X>:			MOVi %1 #ARRAY_SIZE
						ADRL %2 myArray:0 *ARRAY_SIZE
;						PEEK p &FuncPtr
						CALL &FindSmallest %1 *4
						FORi i #2000 @loop.64
						MOVi out %3
						MOVE %1 %4
						CALL ^printFloat %0 *1
						CALL ^printLF
							
						MOVi %1 #ZERO
						CALL ^printInt %0 *1
						CALL ^printLF
							
						MOVi %1 #ONE
						CALL ^printInt %0 *1
						CALL ^printLF %0 *1
						
						MOVi %1 #TWO
						CALL ^printInt %0 *1
						CALL ^printLF %0 *1
						
						MOVp %1 &TestArray:2
						CALL ^printInt %0 *1
						CALL ^printLF
							
						MOVp %1 &HelloString
						CALL ^print %0 *1
							
						MOVp %1 &O
						CALL ^print %0 *1
						CALL ^printLF
							
						MOVi %0 #5
						CALL &TestSwitch %0 *1
							
						MOVi %0 #5
						ADDi %0 #5 %0
						CALL &TestSwitch %0 *1
							
						MOVi %0 #21
						CALL &TestSwitch %0 *1
						
						NEQi #100 #100 @baaad
						NEQf #5.5 #5.5 @baaad
						NEQp &Pointy &Pointy @baaad
						
	return:				RETU
	baaad:				CALL ^abort
						RETU
						
;-------------------------------------------------------------------------------
TestSwitch:				FUNC
	x:					INPi
;-------------------------------------------------------------------------------
						SWCH x *20 @mySwitch
	! MOVi <X> #5
	mySwitch#<X>:		MOVp %1 &Number5
						GOTO @printIt
	mySwitch#10:		MOVp %1 &Number10
						GOTO @printIt
	mySwitch:			MOVp %1 &Defaulty
	printIt:			CALL ^print %0 *1
						RETU

;-------------------------------------------------------------------------------
FillRnd.seed:			GLOB *1
;-------------------------------------------------------------------------------
						DATi #0x92d68ca2

;-------------------------------------------------------------------------------
FuncPtr:				GLOB *1
;-------------------------------------------------------------------------------
						DATp &FindSmallest

;-------------------------------------------------------------------------------
TestArray:				TEMP *3
;-------------------------------------------------------------------------------
						DATi #ZERO
						DATi #ONE
						DATi #TWO

;-------------------------------------------------------------------------------
						CNST *19
;-------------------------------------------------------------------------------
	Number5:			DATs number5
						DATi #10
						DATi #0
	Number10:			DATs number10
						DATi #10
						DATi #0

;-------------------------------------------------------------------------------
Defaulty:				CNST *10
;-------------------------------------------------------------------------------
						DATs defaulty
						DATi #10
						DATi #0

;-------------------------------------------------------------------------------
FillRnd:				FUNC
	count:				INPi ; %0
	pointer:			INPp ; %1 : float array
;-------------------------------------------------------------------------------
	rnd:				LOCi
	tmp:				LOCi
	rndF:				LOCf
	endPointer:			LOCp
	p:					LOCp
; - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
						PEEK rnd &FillRnd.seed
						
						MOVp p pointer
						ADDp endPointer p count
						EQUp p endPointer @done
	loop:				SHLi tmp rnd #+13
						XORi rnd rnd tmp
						SHRu tmp rnd #17
						XORi rnd rnd tmp
						SHLi tmp rnd #5
						XORi rnd rnd tmp
						iTOf rndF rnd #1.0
						GEQf rndF #0.0 @pos
						! iTOf <X> #0x40000000 #4.0
						ADDf rndF rndF #<X>
	pos:				POKE p #0 rndF
						POKE &GlobTest #23
						FORp p endPointer @loop

	done:				POKE &FillRnd.seed rnd
						RETU


;-------------------------------------------------------------------------------
FindSmallest:			FUNC
	count:				INPi	; %0
	array:				INPp	; %1
	index:				OUTi	; %2
	value:				OUTf	; %3
;-------------------------------------------------------------------------------
	i:					LOCi
	tmp:				LOCf
; - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
						LEQi count #0 @done
						PEEK value array #0
						MOVi index #0
						MOVi i #1
	loop:				PEEK tmp array i
						GEQf tmp value @noless
						MOVf value tmp
						MOVi index i
	noless:				FORi i count @loop
	done:				RETU
 

;-------------------------------------------------------------------------------
CallTests:				FUNC
;-------------------------------------------------------------------------------
	i:					LOCi
; - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
						MOVi i #0
	loop:				MOVf %1 #3.3
						MOVf %2 #7.7
						CALL ^testCallback %0 *3
						FORi i #20000000 @loop
						MOVE %1 %0
						CALL ^printFloat %1 *1
						CALL ^printLF
						RETU

					
;-------------------------------------------------------------------------------
MyTestMul:				FUNC
	z:					OUTf
	x:					INPf
	y:					INPf
;-------------------------------------------------------------------------------
						MULf z x y
						RETU


;-------------------------------------------------------------------------------
Fib:					FUNC
r:						OUTi
k:						INPi
;-------------------------------------------------------------------------------
						MOVi r #1
						LEQi k #2 @return
						SUBi %1 k #1
						CALL &Fib %0 *2
						MOVi r %0
						SUBi %1 k #2
						CALL &Fib %0 *2
						ADDi r r %0
	return:				RETU
